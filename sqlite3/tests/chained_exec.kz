// Test: Chained exec with void events (print.ln) in between
// This exercises the void pipeline chaining fix

~import libs/sqlite3
~import std/io

~libs/sqlite3:open(path: ":memory:")
| db d |> libs/sqlite3:exec(conn: d, sql: "CREATE TABLE users (id INTEGER, name TEXT)")
    | ok |> std/io:print.ln("Table created") |> libs/sqlite3:exec(conn: d, sql: "INSERT INTO users VALUES (1, 'Alice')")
        | ok |> std/io:print.ln("Row inserted") |> libs/sqlite3:close(conn: d) |> std/io:print.ln("Done!")
        | err e3 |> libs/sqlite3:close(conn: d) |> std/io:print.ln("Insert error: {{ e3.msg:s }}")
    | err e2 |> libs/sqlite3:close(conn: d) |> std/io:print.ln("Create error: {{ e2.msg:s }}")
| err _ |> std/io:print.ln("Open error")
