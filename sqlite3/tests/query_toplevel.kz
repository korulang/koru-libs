// Test: setup + chained exec, then close (no query transform)

~import libs/sqlite3
~import std/io

// First open and setup the database, storing conn for later
~libs/sqlite3:open(path: ":memory:")
| db d |> libs/sqlite3:exec(d, sql: "CREATE TABLE users (id INTEGER, name TEXT)")
    | ok d2 |> libs/sqlite3:exec(d2, sql: "INSERT INTO users VALUES (42, 'Alice')")
        | ok d3 |> std/io:print.ln("Database setup complete") |> libs/sqlite3:close(d3)
        | err e3 |> libs/sqlite3:close(e3.conn) |> std/io:print.ln("Insert error")
    | err e2 |> libs/sqlite3:close(e2.conn) |> std/io:print.ln("Create error")
| err _ |> std/io:print.ln("Open error")
