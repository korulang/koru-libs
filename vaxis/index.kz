// Koru Vaxis Library — Reactive TUI wrapper, effect-branch shape
// ===============================================================
//
// `run` is a single long-running proc that owns the terminal for its
// entire body: init → loop emitting effects → deinit. Consumers handle
// terminal events as effect branches; they don't write an outer loop.
//
// USAGE:
//   ~import koru/vaxis
//
//   ~koru/vaxis:run(title: "Hello")
//   ! ready |> koru/vaxis:write-at(x: 2, y: 2, text: "Hello! Press q to quit.") |> koru/vaxis:render()
//   ! key k when k.ch == 'q' |> koru/vaxis:quit()
//   ! resize _ |> koru/vaxis:render()
//   | done _ |> _
//   | err e |> _
//
// MODULE-SCOPE REACH-BACK ($mod.):
//   `run` is an effect-branch event, so its |zig body is SPLICED into the
//   consumer's frame (cut-1 inlining) — where this module's bare names don't
//   exist. Every reference to this module's own state (the vars/consts below)
//   from inside a proc body uses the sanctioned `$mod.` spelling so the
//   emitter rewrites it to the right namespace on the splice path and strips
//   it to bare names on the standalone-handler path. `std` is exempt (it
//   auto-rewrites to @import("std")). See koru pin 400_155 for the contract.

~import std/build
~import std/deps

// Zig package dependency — libvaxis from Zig package manager
~std/deps:requires.zig {
    "name": "vaxis",
    "url": "git+https://github.com/rockorager/libvaxis.git#75035b169e91a51c233f3742161f8eb8eafca659",
    "hash": "vaxis-0.5.1-BWNV_IE-CQBYmSf_boEKUyv6den0Gmj5LksxvdCx2pBL"
}

// For BACKEND compilation (so it can validate the generated code)
~std/compiler:requires {
    const vaxis_dep = b.dependency("vaxis", .{
        .target = target,
        .optimize = optimize,
    });
    exe.root_module.addImport("vaxis", vaxis_dep.module("vaxis"));
}

// For OUTPUT binary (the final executable)
~std/build:requires {
    const vaxis_dep = b.dependency("vaxis", .{
        .target = target,
        .optimize = optimize,
    });
    exe.root_module.addImport("vaxis", vaxis_dep.module("vaxis"));
}

const std = @import("std");
const libvaxis = @import("vaxis");

// Zig types for event payloads. KeyData carries a non-optional `ch`
// (0 for non-ASCII) to keep `when k.ch == 'q'` guards straightforward.
const KeyMods = struct {
    ctrl: bool = false,
    alt: bool = false,
    shift: bool = false,
    super_key: bool = false,
};

const KeyData = struct {
    codepoint: u21,
    ch: u8,
    mods: KeyMods,
};

const SizeData = struct {
    width: u16,
    height: u16,
};

// A text style — a reusable value (option B). Boolean attrs + packed RGB
// colors (0 = terminal default; otherwise 0xRRGGBB → libvaxis Color.rgb).
// Maps onto libvaxis Cell.Style (ul / underline style still deferred).
// Floated Charm progress wall (COMPONENT replay 03): Style had no Color.
const Style = struct {
    bold: bool = false,
    dim: bool = false,
    italic: bool = false,
    strikethrough: bool = false,
    fg: u32 = 0,
    bg: u32 = 0,
};

// A window — a positioned, sized VIEW into the screen. Cheap value (offsets +
// dims + a screen pointer), copied freely: no allocation, no obligation. koru
// holds it opaquely and passes it around. Children position RELATIVE to their
// parent, so moving a box moves its contents.
const Window = libvaxis.Window;

// Live StackPanel cursor — parent window plus the next row y the container will
// hand out. The VALUE carries the parent (so stack-row knows what to slice);
// next_y rides module state because koru passes structs by value and a
// sweep's many stack-row calls must share one advancing cursor for the frame.
// Single live stack per frame (vaxis is single-instance); `stack` resets it.
const Stack = struct {
    parent: Window,
};
var stack_next_y: u16 = 0;

// Module-level runtime state. The whole library is single-instance per
// program; `run` is the lifecycle owner.
var vx: libvaxis.Vaxis = undefined;
var tty: libvaxis.Tty = undefined;
var event_loop: libvaxis.Loop(VaxisEvent) = undefined;
// (Zig import is `libvaxis`, not `vaxis` — the Koru module is also named
// `vaxis` and would create an ambiguous reference inside this wrapper.
// Same convention as pq using `c` for the C-import alias.)
var is_initialized: bool = false;
var should_quit: bool = false;
var alloc: std.mem.Allocator = undefined;
var tty_buffer: [4096]u8 = undefined;

// Frame text arena. libvaxis's Screen.writeCell stores a BORROW of the grapheme
// slice (Screen.zig: `self.buf[i] = cell`, Cell.grapheme is []const u8 — no byte
// copy), read only at the deferred render(). So the bytes must outlive the
// producing flow. write-* copy their text HERE, into vaxis-owned storage, so an
// ephemeral `string<allocated!>` (fmt output) can discharge immediately after
// the copy — the lifetime tension is vaxis's to own, not the caller's. Reset on
// clear() (a full-redraw's "new frame" boundary).
var text_arena: std.heap.ArenaAllocator = undefined;

// Internal event type for vaxis loop
const VaxisEvent = union(enum) {
    key_press: libvaxis.Key,
    winsize: libvaxis.Winsize,
    focus_in,
    focus_out,
};

// ============================================================================
// THE MAIN EVENT: run
// ============================================================================
//
// Effect branches:
//   ! ?draw Window     — mount + damage redraw (retained view)
//   ! ?key KeyData     — every key press
//   ! ?resize SizeData — every terminal resize (including initial)
//   ! ?focus-in        — terminal got focus (optional)
//   ! ?focus-out       — terminal lost focus (optional)
//   ! ?tick i64        — animation frame pulse; payload = monotonic ms.
//                        Optional: omitting keeps blocking nextEvent (no
//                        timer wake tax). Installing `! tick` switches to
//                        tryEvent + ~60 Hz ticks (Charm spinner / spring).
//
// Terminals:
//   | done             — clean exit
//   | err string       — init failure

~pub event run { title: string }
! ?draw koru/vaxis:Window
! ?key koru/vaxis:KeyData
! ?resize koru/vaxis:SizeData
! ?focus-in
! ?focus-out
! ?tick i64
| ?done
| err string

~proc run|zig {
    _ = title;  // title is accepted but not yet threaded into vaxis init
    $mod.alloc = std.heap.page_allocator;
    $mod.text_arena = std.heap.ArenaAllocator.init($mod.alloc);
    $mod.should_quit = false;

    $mod.tty = $mod.libvaxis.Tty.init(&$mod.tty_buffer) catch |e| {
        return .{ .err = @errorName(e) };
    };

    $mod.vx = $mod.libvaxis.init($mod.alloc, .{}) catch |e| {
        return .{ .err = @errorName(e) };
    };

    $mod.event_loop = .{ .vaxis = &$mod.vx, .tty = &$mod.tty };
    $mod.event_loop.init() catch |e| {
        return .{ .err = @errorName(e) };
    };
    $mod.event_loop.start() catch |e| {
        return .{ .err = @errorName(e) };
    };

    $mod.vx.enterAltScreen($mod.tty.writer()) catch {};
    $mod.vx.queryTerminal($mod.tty.writer(), 1 * std.time.ns_per_s) catch {};

    // Wait for initial resize so the window has dimensions before any
    // render call. Don't fire `! resize` yet — we'll do that as the first
    // event after mount so consumers see a consistent ordering.
    var initial_size: ?$mod.libvaxis.Winsize = null;
    while (initial_size == null) {
        const ev = $mod.event_loop.nextEvent();
        switch (ev) {
            .winsize => |ws| {
                $mod.vx.resize($mod.alloc, $mod.tty.writer(), ws) catch {};
                initial_size = ws;
            },
            else => {},
        }
    }

    $mod.is_initialized = true;

    // Fire ! draw, handing the consumer the ROOT WINDOW as the payload — the
    // canvas to paint into (`! draw w |> app(win: w)`). This is the RETAINED-view
    // hook: it fires here on MOUNT, and again on every resize (below), so the
    // scene is declared once and repainted on damage. Auto-render after so
    // consumers don't call render() themselves.
    draw($mod.vx.window());
    $mod.vx.render($mod.tty.writer()) catch {};

    // Fire initial ! resize so consumers that only redraw on resize get
    // triggered immediately. Auto-render after.
    const init_ws = initial_size.?;
    resize(.{ .width = init_ws.cols, .height = init_ws.rows });
    $mod.vx.render($mod.tty.writer()) catch {};

    const repaint = struct {
        fn call() void {
            if ($mod.should_quit) return;
            const win = $mod.vx.window();
            win.clear();
            _ = $mod.text_arena.reset(.retain_capacity);
            draw(win);
            $mod.vx.render($mod.tty.writer()) catch {};
        }
    }.call;

    const handle = struct {
        fn call(ev: $mod.VaxisEvent) void {
            switch (ev) {
                .key_press => |k| {
                    if (k.codepoint > 0x3000 or k.codepoint == 0) return;
                    // Prefer libvaxis `text` (what the terminal typed — Shift/
                    // Caps aware). Fall back to shifted_codepoint, then the
                    // base codepoint. Old path used only codepoint → lowercase
                    // forever (text-input gallery bug, 2026-07-23).
                    const ch_val: u8 = blk: {
                        if (k.text) |t| {
                            if (t.len >= 1 and t[0] < 128) break :blk t[0];
                        }
                        if (k.shifted_codepoint) |scp| {
                            if (scp > 0 and scp < 128) break :blk @intCast(scp);
                        }
                        if (k.codepoint > 0 and k.codepoint < 128) break :blk @intCast(k.codepoint);
                        break :blk 0;
                    };
                    key(.{
                        .codepoint = k.codepoint,
                        .ch = ch_val,
                        .mods = .{
                            .ctrl = k.mods.ctrl,
                            .alt = k.mods.alt,
                            .shift = k.mods.shift,
                            .super_key = k.mods.super,
                        },
                    });
                    repaint();
                },
                .winsize => |ws| {
                    // Dedup: libvaxis re-emits winsize during startup; vx.resize
                    // wipes the buffer — only act on real dimension changes.
                    if ($mod.vx.screen.width != ws.cols or $mod.vx.screen.height != ws.rows) {
                        $mod.vx.resize($mod.alloc, $mod.tty.writer(), ws) catch {};
                        resize(.{
                            .width = ws.cols,
                            .height = ws.rows,
                        });
                        draw($mod.vx.window());
                        $mod.vx.render($mod.tty.writer()) catch {};
                    }
                },
                .focus_in => {
                    focus_in();
                },
                .focus_out => {
                    focus_out();
                },
            }
        }
    }.call;

    // Presence-gated loop: `@hasDecl(__H, "tick")` — void optional arms get
    // noop stand-ins (not nullable fns; 400_148 is for value-resuming arms).
    // With a real `! tick` handler → tryEvent + ~60 Hz; without → blocking
    // nextEvent (no timer wake tax on todo/gallery-without-animation).
    if (@hasDecl(__H, "tick")) {
        const tick_period_ns: i128 = 16 * std.time.ns_per_ms;
        var next_tick: i128 = std.time.nanoTimestamp() + tick_period_ns;
        while (!$mod.should_quit) {
            while ($mod.event_loop.tryEvent()) |ev| {
                handle(ev);
                if ($mod.should_quit) break;
            }
            if ($mod.should_quit) break;
            const now: i128 = std.time.nanoTimestamp();
            if (now >= next_tick) {
                next_tick = now + tick_period_ns;
                const ms: i64 = @intCast(@divTrunc(now, std.time.ns_per_ms));
                tick(ms);
                repaint();
            } else {
                const remain: i128 = next_tick - now;
                const sleep_ns: u64 = if (remain <= 0) 0 else @intCast(@min(remain, tick_period_ns));
                if (sleep_ns > 0) std.Thread.sleep(sleep_ns);
            }
        }
    } else {
        while (!$mod.should_quit) {
            handle($mod.event_loop.nextEvent());
        }
    }

    // Cleanup inside the producer body — no separate `cleanup` event needed.
    $mod.vx.deinit($mod.alloc, $mod.tty.writer());
    $mod.tty.deinit();
    $mod.text_arena.deinit();
    $mod.is_initialized = false;

    return .{ .done = .{} };
}

// ============================================================================
// CONSUMER-FACING UTILITIES
// ============================================================================

// Request quit. Sets the flag the `run` loop checks each iteration.
~pub event quit {}

~proc quit|zig {
    $mod.should_quit = true;
}

// Render the current frame to the terminal.
~pub event render {}

~proc render|zig {
    if ($mod.is_initialized) {
        $mod.vx.render($mod.tty.writer()) catch {};
    }
}

// Clear the screen.
~pub event clear {}

~proc clear|zig {
    if ($mod.is_initialized) {
        const win = $mod.vx.window();
        win.clear();
        // A full redraw starts here — every cell is blanked, so no cell borrows
        // last frame's text. Reclaim the frame arena for the redraw's writes.
        _ = $mod.text_arena.reset(.retain_capacity);
    }
}

// Write text at position.
~pub event write-at { x: u16, y: u16, text: string }

~proc write-at|zig {
    if ($mod.is_initialized) {
        const win = $mod.vx.window();
        const child = win.child(.{ .x_off = x, .y_off = y });
        // Own the bytes for the frame — the caller's `text` (a literal, a store
        // value, or an ephemeral fmt result) is not ours to keep alive.
        const owned = $mod.text_arena.allocator().dupe(u8, text) catch text;
        // Grapheme walk via libvaxis print — byte-sliced writeCell shattered
        // UTF-8 meter runes (▌/░/█). Charm progress wall 2.
        _ = child.printSegment(.{ .text = owned }, .{});
    }
}

// Construct a reusable Style value. Bind it once (`: style`) and it puns into
// every downstream write-styled's `style:` param; or pass it explicitly. No
// param defaults yet, so all attrs are named here — partial specs ride the
// struct defaults via an inline `{ … }` record literal instead.
~pub event style { bold: bool, dim: bool, italic: bool, strikethrough: bool } -> koru/vaxis:Style

~proc style|zig {
    return .{ .bold = bold, .dim = dim, .italic = italic, .strikethrough = strikethrough, .fg = 0, .bg = 0 };
}

// Write text at position WITH a style. `style` is a reusable Style value —
// bind it once, apply to many writes. The koru Style maps onto libvaxis
// Cell.Style (bools + fg/bg RGB; 0 color = .default).
~pub event write-styled { x: u16, y: u16, text: string, style: koru/vaxis:Style }

~proc write-styled|zig {
    if ($mod.is_initialized) {
        const win = $mod.vx.window();
        const child = win.child(.{ .x_off = x, .y_off = y });
        const cell_style: $mod.libvaxis.Cell.Style = .{
            .bold = style.bold,
            .dim = style.dim,
            .italic = style.italic,
            .strikethrough = style.strikethrough,
            .fg = if (style.fg == 0) .default else $mod.libvaxis.Color.rgbFromUint(@intCast(style.fg)),
            .bg = if (style.bg == 0) .default else $mod.libvaxis.Color.rgbFromUint(@intCast(style.bg)),
        };
        const owned = $mod.text_arena.allocator().dupe(u8, text) catch text;
        _ = child.printSegment(.{ .text = owned, .style = cell_style }, .{});
    }
}

// Open a child window (a positioned, sized region) of the root and return it as
// a value. Bind it (`: win`) and downstream write-in calls pun `win` to paint
// INTO it with box-relative coords. `border` draws a frame around the region.
~pub event box { x: u16, y: u16, w: u16, h: u16, border: bool } -> koru/vaxis:Window

~proc box|zig {
    const root = $mod.vx.window();
    return root.child(.{
        .x_off = x,
        .y_off = y,
        .width = w,
        .height = h,
        .border = .{ .where = if (border) .all else .none },
    });
}

// Slice a sub-window out of a GIVEN parent window (not the root) — the primitive
// a layout container uses to carve its own region into child slots. Offsets are
// parent-relative and cumulative (a sub of a sub composes), so moving the parent
// moves the whole subtree. `w`/`h` of 0 mean FILL to the parent's edge (libvaxis
// takes ?u16, null = fill) — a StackPanel row is `sub(parent, x:0, y:i, w:0, h:1)`:
// full width, one row tall, at row i.
~pub event sub { parent: koru/vaxis:Window, x: u16, y: u16, w: u16, h: u16 } -> koru/vaxis:Window

~proc sub|zig {
    return parent.child(.{
        .x_off = x,
        .y_off = y,
        .width = if (w == 0) null else w,
        .height = if (h == 0) null else h,
    });
}

// Dock a child of height `h` at the BOTTOM edge of the parent, `up` rows up from
// that edge (up = this child's height plus everything already docked below it).
// The parent's RUNTIME height is read here — bottom-pinning is the one thing that
// cannot be comptime-folded, because the terminal height changes on resize. This
// is precisely the primitive StackPanel never needed: fixed top rows never touch
// the far edge, so they stay pure arithmetic; the bottom edge does not.
~pub event sub-from-bottom { parent: koru/vaxis:Window, up: u16, h: u16 } -> koru/vaxis:Window

~proc sub-from-bottom|zig {
    var y: i32 = @as(i32, parent.height) - @as(i32, up);
    if (y < 0) y = 0;
    return parent.child(.{
        .x_off = 0,
        .y_off = @as(i17, @intCast(y)),
        .width = null,
        .height = h,
    });
}

// The FILL slot: the middle band between the top-docked rows (`top`) and the
// bottom-docked rows (`bottom`). Height = parent.height - top - bottom, resolved
// at runtime so the fill grows and shrinks with the terminal — classic Dock's
// last-child-fill, expressed as a koru Window value.
~pub event sub-fill { parent: koru/vaxis:Window, top: u16, bottom: u16 } -> koru/vaxis:Window

~proc sub-fill|zig {
    var hh: i32 = @as(i32, parent.height) - @as(i32, top) - @as(i32, bottom);
    if (hh < 0) hh = 0;
    return parent.child(.{
        .x_off = 0,
        .y_off = @as(i17, @intCast(top)),
        .width = null,
        .height = @as(u16, @intCast(hh)),
    });
}

// Live stack-panel — runtime cursor over a parent window. Static markup
// `<stack-panel>` still comptime-folds fixed children; this is the draw-time
// twin for store-driven rows (sweep pushes children; they never pass `y:`).
//
//   |> stack(parent: body): panel
//   |> sweep(todos)
//   ! sweep … |> stack-row(stack: panel): rw |> todo-row(win: rw, …)
~pub event stack { parent: koru/vaxis:Window } -> koru/vaxis:Stack

~proc stack|zig {
    $mod.stack_next_y = 0;
    return .{ .parent = parent };
}

// Next 1-line full-width slice of the stack's parent. Advances the frame cursor.
// Layout stays the container's job — the child paints into the returned window.
~pub event stack-row { stack: koru/vaxis:Stack } -> koru/vaxis:Window

~proc stack-row|zig {
    const y = $mod.stack_next_y;
    $mod.stack_next_y = y + 1;
    return stack.parent.child(.{
        .x_off = 0,
        .y_off = @as(i17, @intCast(y)),
        .width = null,
        .height = 1,
    });
}

// Write text INTO a window, at coords relative to that window's top-left. Moving
// the window moves everything written into it — the retained-layout payoff.
~pub event write-in { win: koru/vaxis:Window, x: u16, y: u16, text: string }

~proc write-in|zig {
    if ($mod.is_initialized) {
        const child = win.child(.{ .x_off = x, .y_off = y });
        const owned = $mod.text_arena.allocator().dupe(u8, text) catch text;
        _ = child.printSegment(.{ .text = owned }, .{});
    }
}

// Charm-class progress meter — fill math + per-cell color blend live HERE
// (COMPONENT wall 3). Defaults match bubbles/progress: ▌ filled (half-block
// dual-color blend), ░ empty, purple→pink (#5A56E0→#EE6FF8), empty #606060,
// trailing " N%". Width = win.width (stack/dock rows hand a slice). Component
// markup tags `<progress-bar …/>` resolve to this event (builtin path), so the
// widget boundary owns the meter.
~pub event progress-bar { win: koru/vaxis:Window, value: i64, max: i64 }

~proc progress-bar|zig {
    if (!$mod.is_initialized) return;

    const max_v: i64 = if (max <= 0) 1 else max;
    var v: i64 = value;
    if (v < 0) v = 0;
    if (v > max_v) v = max_v;
    const pct: f64 = @as(f64, @floatFromInt(v)) / @as(f64, @floatFromInt(max_v));

    // Charm defaults
    const blend_start: u32 = 0x5A56E0;
    const blend_end: u32 = 0xEE6FF8;
    const empty_color: u32 = 0x606060;
    const full_g = "▌";
    const empty_g = "░";

    var pct_buf: [8]u8 = undefined;
    const pct_text = std.fmt.bufPrint(&pct_buf, " {d}%", .{@as(u32, @intFromFloat(@round(pct * 100.0)))}) catch " ?%";
    const pct_w: u16 = @intCast(pct_text.len);

    var total_w: u16 = win.width;
    if (total_w < pct_w + 1) total_w = pct_w + 1;
    const bar_w: u16 = total_w - pct_w;
    var filled: u16 = @intFromFloat(@round(pct * @as(f64, @floatFromInt(bar_w))));
    if (filled > bar_w) filled = bar_w;

    const lerp = struct {
        fn call(a: u32, b: u32, t: f64) u32 {
            const ar: f64 = @floatFromInt((a >> 16) & 0xff);
            const ag: f64 = @floatFromInt((a >> 8) & 0xff);
            const ab: f64 = @floatFromInt(a & 0xff);
            const br: f64 = @floatFromInt((b >> 16) & 0xff);
            const bg: f64 = @floatFromInt((b >> 8) & 0xff);
            const bb: f64 = @floatFromInt(b & 0xff);
            const r: u32 = @intFromFloat(ar + (br - ar) * t);
            const g: u32 = @intFromFloat(ag + (bg - ag) * t);
            const bl: u32 = @intFromFloat(ab + (bb - ab) * t);
            return (r << 16) | (g << 8) | bl;
        }
    }.call;

    // Half-block: each cell's fg/bg are adjacent samples on a 2× denser blend
    // across the full bar width (Charm WithDefaultBlend + ▌).
    const samples: u32 = if (bar_w == 0) 1 else @as(u32, bar_w) * 2;
    const denom: f64 = @floatFromInt(if (samples <= 1) @as(u32, 1) else samples - 1);
    var col: u16 = 0;
    while (col < filled) : (col += 1) {
        const sample0: u32 = @as(u32, col) * 2;
        const t0: f64 = @as(f64, @floatFromInt(sample0)) / denom;
        const t1: f64 = @as(f64, @floatFromInt(sample0 + 1)) / denom;
        const c0 = lerp(blend_start, blend_end, t0);
        const c1 = lerp(blend_start, blend_end, t1);
        win.writeCell(col, 0, .{
            .char = .{ .grapheme = full_g, .width = 1 },
            .style = .{
                .fg = $mod.libvaxis.Color.rgbFromUint(@intCast(c0)),
                .bg = $mod.libvaxis.Color.rgbFromUint(@intCast(c1)),
            },
        });
    }
    while (col < bar_w) : (col += 1) {
        win.writeCell(col, 0, .{
            .char = .{ .grapheme = empty_g, .width = 1 },
            .style = .{
                .fg = $mod.libvaxis.Color.rgbFromUint(@intCast(empty_color)),
            },
        });
    }

    const pct_owned = $mod.text_arena.allocator().dupe(u8, pct_text) catch pct_text;
    const pct_child = win.child(.{ .x_off = bar_w, .y_off = 0 });
    _ = pct_child.printSegment(.{ .text = pct_owned }, .{});
}

// Charm-class spinner — glyph cycling + Style fg + MiniDot FPS live HERE
// (COMPONENT spinner). Defaults match bubbles/spinner MiniDot + Charm purple
// #5A56E0. `ms` is monotonic tick payload; widget owns frame index + period.
// Markup tag `<spinner …/>` resolves via builtin wa_qual path.
~pub event spinner { win: koru/vaxis:Window, ms: i64 }

~proc spinner|zig {
    if (!$mod.is_initialized) return;

    // bubbles/spinner MiniDot — 10 frames @ time.Second/12
    const frames = [_][]const u8{ "⠋", "⠙", "⠹", "⠸", "⠼", "⠴", "⠦", "⠧", "⠇", "⠏" };
    const period_ms: i64 = @divTrunc(1000, 12);
    const t: i64 = if (ms < 0) 0 else ms;
    const idx: usize = @intCast(@mod(@divTrunc(t, period_ms), @as(i64, @intCast(frames.len))));
    const glyph = frames[idx];

    // Charm progress purple — same taste floor as the meter
    const fg: u32 = 0x5A56E0;
    const owned = $mod.text_arena.allocator().dupe(u8, glyph) catch glyph;
    const cell_style: $mod.libvaxis.Cell.Style = .{
        .fg = $mod.libvaxis.Color.rgbFromUint(@intCast(fg)),
    };
    _ = win.printSegment(.{ .text = owned, .style = cell_style }, .{});
}

// Charm-class textinput — prompt + value/placeholder + blink block cursor +
// horizontal scroll live HERE (COMPONENT textinput). Defaults match Bubbles:
// Prompt "> ", placeholder when empty, focused purple prompt, dim placeholder,
// blink ~530ms from `ms` tick. Cursor always at end (append-char/pop-char
// path — no mid-buffer caret yet). Markup `<text-input …/>` via wa_qual.
~pub event text-input { win: koru/vaxis:Window, value: string, ms: i64 }

~proc text-input|zig {
    if (!$mod.is_initialized) return;

    const prompt = "> ";
    const placeholder = "Type something...";
    const prompt_fg: u32 = 0x5A56E0; // Charm purple
    const text_fg: u32 = 0xE0DEF4;
    const placeholder_fg: u32 = 0x606060;
    const cursor_bg: u32 = 0x5A56E0;
    const cursor_fg: u32 = 0xFFFFFF;
    // bubbles/cursor default blink cadence (~530ms)
    const t: i64 = if (ms < 0) 0 else ms;
    const blink_on: bool = @mod(@divTrunc(t, 530), 2) == 0;

    const arena = $mod.text_arena.allocator();
    const prompt_owned = arena.dupe(u8, prompt) catch prompt;
    const prompt_style: $mod.libvaxis.Cell.Style = .{
        .fg = $mod.libvaxis.Color.rgbFromUint(@intCast(prompt_fg)),
        .bold = true,
    };
    _ = win.printSegment(.{ .text = prompt_owned, .style = prompt_style }, .{});

    const prompt_w: u16 = @intCast(prompt.len);
    const total_w: u16 = win.width;
    if (total_w <= prompt_w) return;
    const avail: u16 = total_w - prompt_w;

    const empty = value.len == 0;
    // Horizontal viewport: one cell reserved for the end cursor (Charm scroll).
    const view_w: usize = if (avail == 0) 0 else @as(usize, avail);
    var offset: usize = 0;
    if (!empty) {
        const need: usize = value.len + 1; // text + cursor cell
        if (need > view_w and view_w > 0) {
            offset = need - view_w;
            if (offset > value.len) offset = value.len;
        }
    }

    var col: u16 = prompt_w;
    if (empty) {
        // Placeholder: first cell is the blink cursor (Charm placeholderView).
        const ph = placeholder;
        if (ph.len > 0 and col < total_w) {
            const first = arena.dupe(u8, ph[0..1]) catch ph[0..1];
            if (blink_on) {
                win.writeCell(col, 0, .{
                    .char = .{ .grapheme = first, .width = 1 },
                    .style = .{
                        .fg = $mod.libvaxis.Color.rgbFromUint(@intCast(cursor_fg)),
                        .bg = $mod.libvaxis.Color.rgbFromUint(@intCast(cursor_bg)),
                    },
                });
            } else {
                win.writeCell(col, 0, .{
                    .char = .{ .grapheme = first, .width = 1 },
                    .style = .{
                        .fg = $mod.libvaxis.Color.rgbFromUint(@intCast(placeholder_fg)),
                    },
                });
            }
            col += 1;
        }
        if (ph.len > 1 and col < total_w) {
            const rest_end: usize = @min(ph.len, @as(usize, avail));
            if (rest_end > 1) {
                const rest = arena.dupe(u8, ph[1..rest_end]) catch ph[1..rest_end];
                const child = win.child(.{ .x_off = col, .y_off = 0 });
                const ph_style: $mod.libvaxis.Cell.Style = .{
                    .fg = $mod.libvaxis.Color.rgbFromUint(@intCast(placeholder_fg)),
                };
                _ = child.printSegment(.{ .text = rest, .style = ph_style }, .{});
            }
        }
        return;
    }

    // Visible slice of value (ASCII — append-char feeds u8).
    const vis = value[offset..];
    const text_style: $mod.libvaxis.Cell.Style = .{
        .fg = $mod.libvaxis.Color.rgbFromUint(@intCast(text_fg)),
    };
    if (vis.len > 0 and col < total_w) {
        const max_chars: usize = @min(vis.len, @as(usize, total_w - col));
        // Leave room for cursor cell when it fits.
        const paint_n: usize = if (max_chars + col < total_w)
            max_chars
        else if (max_chars > 0) max_chars - 1 else 0;
        if (paint_n > 0) {
            const owned = arena.dupe(u8, vis[0..paint_n]) catch vis[0..paint_n];
            const child = win.child(.{ .x_off = col, .y_off = 0 });
            _ = child.printSegment(.{ .text = owned, .style = text_style }, .{});
            col += @intCast(paint_n);
        }
    }

    // End cursor — blink block (Charm virtual cursor at EOL).
    if (col < total_w) {
        const cursor_ch = arena.dupe(u8, " ") catch " ";
        if (blink_on) {
            win.writeCell(col, 0, .{
                .char = .{ .grapheme = cursor_ch, .width = 1 },
                .style = .{
                    .fg = $mod.libvaxis.Color.rgbFromUint(@intCast(cursor_fg)),
                    .bg = $mod.libvaxis.Color.rgbFromUint(@intCast(cursor_bg)),
                },
            });
        } else {
            win.writeCell(col, 0, .{
                .char = .{ .grapheme = cursor_ch, .width = 1 },
                .style = text_style,
            });
        }
    }
}

// Charm-class simple list — title + paginated items + selection cursor live
// HERE (COMPONENT list). Matches bubbles/list simple delegate: bold purple
// title (marginLeft 2), each row "<N>. <title>" with paddingLeft 4 (selected
// swaps to paddingLeft 2 + "> " prefix, so the title column stays at x=4 on
// every row). Selected row in Charm pink + bold; unselected in soft contrast.
// Pagination footer at bottom: one dot per page (Charm paginator), current
// page filled ● in pink, others dim ○. Page-aligned scroll keeps the selection
// on the visible page. State (items newlstring + selected index) lives in a
// host store and is fed as props — the widget OWNS paint/chrome, NOT the key
// pipeline. Markup tag `<list …/>` resolves via builtin wa_qual path.
~pub event list { win: koru/vaxis:Window, title: string, items: string, selected: i64 }

~proc list|zig {
    if (!$mod.is_initialized) return;

    const arena = $mod.text_arena.allocator();

    // Charm list-simple palette — project purple/pink family (matching the
    // other Bubbles ports; lipgloss "170" ≈ magenta, rounded to #EE6FF8).
    const title_fg: u32 = 0x5A56E0; // Charm purple — title
    const sel_fg:   u32 = 0xEE6FF8; // Charm pink   — selected row
    const item_fg:  u32 = 0xC8C8D0; // soft contrast — unselected row
    const dot_dim:  u32 = 0x606060; // paginator off-dot

    const w: u16 = win.width;
    const h: u16 = win.height;
    if (w == 0 or h < 4) return;

    // Title row — bold purple, marginLeft 2 (bubbletea list-simple Title style).
    if (title.len > 0) {
        const tbuf = arena.dupe(u8, title) catch title;
        const ts: $mod.libvaxis.Cell.Style = .{
            .fg = $mod.libvaxis.Color.rgbFromUint(@intCast(title_fg)),
            .bold = true,
        };
        const tchild = win.child(.{
            .x_off = 2,
            .y_off = 0,
            .width = if (w > 2) w - 2 else 1,
            .height = 1,
        });
        _ = tchild.printSegment(.{ .text = tbuf, .style = ts }, .{});
    }

    // Items region: y=[2, h-2); paginator row at y=h-1.
    const region_top: u16 = 2;
    const footer_y:   u16 = h - 1;
    const visible_rows: u16 = if (footer_y > region_top) footer_y - region_top else 1;

    // Trim a trailing newline so splitScalar yields exactly the item lines.
    var src: []const u8 = items;
    while (src.len > 0 and src[src.len - 1] == '\n') src = src[0 .. src.len - 1];
    if (src.len == 0) return;

    // Split into arena-owned line slices.
    var lines = std.ArrayList([]const u8).initCapacity(arena, 4) catch unreachable;
    var it = std.mem.splitScalar(u8, src, '\n');
    while (it.next()) |l| lines.append(arena, l) catch unreachable;
    const count: u16 = @intCast(lines.items.len);
    if (count == 0) return;

    // Clamp selected into [0, count-1].
    var sel: i64 = selected;
    if (sel < 0) sel = 0;
    if (sel > @as(i64, @intCast(count)) - 1) sel = @as(i64, @intCast(count)) - 1;
    const sel_idx: u16 = @intCast(sel);

    // Page-aligned scroll (selection kept inside the visible page).
    const page: u16 = if (count > visible_rows) @divTrunc(sel_idx, visible_rows) else 0;
    const first: u16 = page * visible_rows;

    // Render visible rows — one printSegment per row with the merged style.
    var r: u16 = 0;
    while (r < visible_rows) : (r += 1) {
        const idx: u16 = first + r;
        if (idx >= count) break;
        const row_y: u16 = region_top + r;
        const is_sel = (idx == sel_idx);

        const line = lines.items[idx];
        // Charm shape: "<N>. <title>" — N is the 1-based overall index.
        const label = std.fmt.allocPrint(arena, "{d}. {s}", .{ idx + 1, line }) catch continue;
        // paddingLeft 4 unselected; paddingLeft 2 + "> " selected (label still
        // starts at column 4 — matches list-simple's Render).
        const row_text = if (is_sel)
            (std.fmt.allocPrint(arena, "  > {s}", .{label}) catch label)
        else
            (std.fmt.allocPrint(arena, "    {s}", .{label}) catch label);

        const row_style: $mod.libvaxis.Cell.Style = .{
            .fg = $mod.libvaxis.Color.rgbFromUint(@intCast(if (is_sel) sel_fg else item_fg)),
            .bold = is_sel,
        };
        const row_owned = arena.dupe(u8, row_text) catch row_text;
        const rchild = win.child(.{
            .x_off = 0,
            .y_off = row_y,
            .width = w,
            .height = 1,
        });
        _ = rchild.printSegment(.{ .text = row_owned, .style = row_style }, .{});
    }

    // Pagination footer — one dot per page (Charm paginator). Hidden on a
    // single page (no chrome to draw then). Capped at 20 visible dots with a
    // window around the current page so a huge list keeps a tidy footer.
    if (count <= visible_rows) return; // one page, no paginator.

    const total_pages: u16 = @divTrunc(count + visible_rows - 1, visible_rows);
    const max_dots: u16 = 20;
    var dot_start: u16 = 0;
    var dot_end:   u16 = total_pages;
    if (total_pages > max_dots) {
        // Window around the current page (clamped to [0, total_pages]).
        const half: u16 = @divTrunc(max_dots, 2);
        dot_start = if (page > half) page - half else 0;
        dot_end = dot_start + max_dots;
        if (dot_end > total_pages) {
            dot_end = total_pages;
            dot_start = if (total_pages > max_dots) total_pages - max_dots else 0;
        }
    }

    // One printSegment per glyph so the current page can be pink (Charm
    // paginator ActiveDot) while the rest stay dim. A single segment can
    // only carry one style — that was the deferred hole.
    var col: u16 = 4; // paddingLeft 4 — matches item rows
    const dim_style: $mod.libvaxis.Cell.Style = .{
        .fg = $mod.libvaxis.Color.rgbFromUint(@intCast(dot_dim)),
    };
    if (dot_start > 0 and col < w) {
        const ell = arena.dupe(u8, "…") catch "…";
        const echild = win.child(.{
            .x_off = col,
            .y_off = footer_y,
            .width = w - col,
            .height = 1,
        });
        _ = echild.printSegment(.{ .text = ell, .style = dim_style }, .{});
        col +%= 2;
    }
    var p: u16 = dot_start;
    while (p < dot_end) : (p += 1) {
        if (col >= w) break;
        const is_cur = (p == page);
        const glyph: []const u8 = if (is_cur) "●" else "○";
        const ds: $mod.libvaxis.Cell.Style = .{
            .fg = $mod.libvaxis.Color.rgbFromUint(@intCast(if (is_cur) sel_fg else dot_dim)),
            .bold = is_cur,
        };
        const g_owned = arena.dupe(u8, glyph) catch glyph;
        const gchild = win.child(.{
            .x_off = col,
            .y_off = footer_y,
            .width = w - col,
            .height = 1,
        });
        _ = gchild.printSegment(.{ .text = g_owned, .style = ds }, .{});
        col +%= 2; // glyph + trailing gap (Charm "● ")
    }
    if (dot_end < total_pages and col < w) {
        const ell = arena.dupe(u8, "…") catch "…";
        const echild = win.child(.{
            .x_off = col,
            .y_off = footer_y,
            .width = w - col,
            .height = 1,
        });
        _ = echild.printSegment(.{ .text = ell, .style = dim_style }, .{});
    }
}

// Charm-class viewport — a scrollable content window (COMPONENT viewport).
// Matches bubbles/viewport's job: content taller than the window, paint ONLY
// the visible slice starting at `offset` (YOffset). Content is a newline-
// delimited string (same payload path as list/text-input); each visible line
// paints into its own 1-row child window so long lines hard-clip at the right
// edge instead of wrapping (bubbles' no-soft-wrap default). The widget is
// chromeless like bubbles' — content renders in the terminal default style;
// scroll position lives in the HOST store and arrives as a prop. Offset is
// clamped to [0, count-1]: the last line can scroll to the top (less/vim
// max-scroll). Bubbles clamps at count-height instead, but the host cannot
// see the window height to mirror that guard — clamping the paint at
// count-height here would leave a key-press dead zone where the host offset
// moves and nothing changes on screen. Floated, not routed around.
// Markup tag `<viewport …/>` resolves via builtin wa_qual path.
~pub event viewport { win: koru/vaxis:Window, content: string, offset: i64 }

~proc viewport|zig {
    if (!$mod.is_initialized) return;

    const arena = $mod.text_arena.allocator();
    const w: u16 = win.width;
    const h: u16 = win.height;
    if (w == 0 or h == 0) return;

    // Trim trailing newlines so splitScalar yields exactly the content lines.
    var src: []const u8 = content;
    while (src.len > 0 and src[src.len - 1] == '\n') src = src[0 .. src.len - 1];
    if (src.len == 0) return;

    // Split into arena-owned line slices (same shape as list).
    var lines = std.ArrayList([]const u8).initCapacity(arena, 8) catch unreachable;
    var it = std.mem.splitScalar(u8, src, '\n');
    while (it.next()) |l| lines.append(arena, l) catch unreachable;
    const count: u16 = @intCast(lines.items.len);
    if (count == 0) return;

    // Clamp offset into [0, count-1].
    var off: i64 = offset;
    if (off < 0) off = 0;
    if (off > @as(i64, @intCast(count)) - 1) off = @as(i64, @intCast(count)) - 1;
    const first: u16 = @intCast(off);

    // Paint the visible slice — one 1-row child per line (hard-clip, no wrap).
    var r: u16 = 0;
    while (r < h) : (r += 1) {
        const idx: u16 = first + r;
        if (idx >= count) break;
        const line = lines.items[idx];
        if (line.len == 0) continue;
        const owned = arena.dupe(u8, line) catch line;
        const lchild = win.child(.{
            .x_off = 0,
            .y_off = r,
            .width = w,
            .height = 1,
        });
        _ = lchild.printSegment(.{ .text = owned }, .{});
    }
}

// Charm-class paginator — pagination STATUS CHROME (COMPONENT paginator).
// Charm's own note: this widget does NOT render page content; it paints the
// page indicator and does the page math. Two display modes matching bubbles/
// paginator's Type:
//   Dots   (default) — one ● per page, the current page's dot pink #EE6FF8 +
//                       bold (Charm ActiveDot), the rest dim ○ (InactiveDot).
//                       Same taste as list's embedded footer; spaced "● ○ ○".
//   Arabic ("kind=arabic") — "N/M" (1-based current / total), current number
//                       pink + bold, "/M" dim (Charm defaults to "%d/%d").
// Both modes center on the widget's row. Page state (current page + total
// pages) lives in the HOST store and arrives as props — the widget OWNS the
// paint, NOT the `! key` pipeline (host keys mutate `page`). The row is
// usually 1 tall (a status row); it paints at y=0 of whatever window it is
// handed. Markup tag `<paginator …/>` resolves via builtin wa_qual path.
~pub event paginator { win: koru/vaxis:Window, page: i64, total: i64, kind: string }

~proc paginator|zig {
    if (!$mod.is_initialized) return;

    const arena = $mod.text_arena.allocator();
    const w: u16 = win.width;
    const h: u16 = win.height;
    if (w == 0 or h == 0) return;

    // Charm paginator palette — pink ActiveDot / current, dim for the rest.
    const active_fg: u32 = 0xEE6FF8; // Charm pink — ActiveDot / current page
    const dim_fg:    u32 = 0x606060; // dim — InactiveDot / total

    // Page math (Charm owns this in the widget). Clamp page into [0, total-1].
    var total_pages: i64 = total;
    if (total_pages < 1) total_pages = 1;
    var pg: i64 = page;
    if (pg < 0) pg = 0;
    if (pg > total_pages - 1) pg = total_pages - 1;
    const cur: u16 = @intCast(pg);
    const tp: u16 = @intCast(total_pages);

    const active_style: $mod.libvaxis.Cell.Style = .{
        .fg = $mod.libvaxis.Color.rgbFromUint(@intCast(active_fg)),
        .bold = true,
    };
    const dim_style: $mod.libvaxis.Cell.Style = .{
        .fg = $mod.libvaxis.Color.rgbFromUint(@intCast(dim_fg)),
    };

    // Arabic mode — "N/M", current 1-based pink+bold, "/M" dim, centered.
    if (std.mem.eql(u8, kind, "arabic")) {
        const num = std.fmt.allocPrint(arena, "{d}", .{cur + 1}) catch return;
        const rest = std.fmt.allocPrint(arena, "/{d}", .{tp}) catch return;
        const total_w: u16 = @intCast(num.len + rest.len);
        var x: u16 = if (w > total_w) (w - total_w) / 2 else 0;
        const c1 = win.child(.{ .x_off = x, .y_off = 0, .width = w - x, .height = 1 });
        _ = c1.printSegment(.{ .text = num, .style = active_style }, .{});
        x +%= @intCast(num.len);
        if (x < w) {
            const c2 = win.child(.{ .x_off = x, .y_off = 0, .width = w - x, .height = 1 });
            _ = c2.printSegment(.{ .text = rest, .style = dim_style }, .{});
        }
        return;
    }

    // Dots mode (default) — one ●/○ per page, current pink+bold, rest dim.
    // Spaced ("● ○ ○" — list-footer taste) and centered. One printSegment per
    // glyph so each dot carries its own style (a segment holds a single style).
    const display_w: u16 = if (tp > 1) tp * 2 - 1 else 1;
    var col: u16 = if (w > display_w) (w - display_w) / 2 else 0;
    var p: u16 = 0;
    while (p < tp) : (p += 1) {
        if (col >= w) break;
        const is_cur = (p == cur);
        const glyph: []const u8 = if (is_cur) "●" else "○";
        const g_owned = arena.dupe(u8, glyph) catch glyph;
        const gchild = win.child(.{ .x_off = col, .y_off = 0, .width = w - col, .height = 1 });
        _ = gchild.printSegment(.{
            .text = g_owned,
            .style = if (is_cur) active_style else dim_style,
        }, .{});
        col +%= 2; // glyph + trailing gap (Charm "● ")
    }
}

// Charm-class help — keybinding hints (COMPONENT help). Matches bubbles/help:
//   SHORT mode (mode=0, default) — a single line "key desc • key desc • …",
//     muted keys (#626262), softer descs (#4A4A4A), dim " • " separators
//     (#3C3C3C); truncated with a trailing "…" when the content is wider than
//     the window (bubbles' width-aware ShortHelpView + ansi.Truncate).
//   FULL mode (mode!=0) — one "key  desc" row per binding, keys right-padded
//     into an aligned column (bubbles' single-column FullHelpView).
// Both anchor to the BOTTOM of the given window (help sits at the screen bottom
// in a real app). Bindings arrive as a host-owned "key:desc\nkey:desc" payload
// (the list/viewport string path — a real structured []Binding with separate
// short/full lists is the deferred hole); `mode` is a host store int the app's
// `?` key toggles — the widget OWNS the paint, NOT the `! key` pipeline.
// Markup tag `<help …/>` resolves via builtin wa_qual path.
~pub event help { win: koru/vaxis:Window, bindings: string, mode: i64 }

~proc help|zig {
    if (!$mod.is_initialized) return;

    const arena = $mod.text_arena.allocator();
    const w: u16 = win.width;
    const h: u16 = win.height;
    if (w == 0 or h == 0) return;

    // bubbles/help DefaultStyles (dark) — muted key, softer desc, dim separator.
    const key_fg:  u32 = 0x626262;
    const desc_fg: u32 = 0x4A4A4A;
    const sep_fg:  u32 = 0x3C3C3C;

    // Display width = UTF-8 rune count (arrows / • / … are one column each; wide
    // CJK is not special-cased — an honest edge, keys are ascii/arrow in Charm).
    const dispW = struct {
        fn call(s: []const u8) usize {
            var n: usize = 0;
            var i: usize = 0;
            while (i < s.len) {
                const cl = std.unicode.utf8ByteSequenceLength(s[i]) catch 1;
                i += cl;
                n += 1;
            }
            return n;
        }
    }.call;
    // First `take` runes of s as a byte slice (rune-safe truncation).
    const takeRunes = struct {
        fn call(s: []const u8, take: usize) []const u8 {
            var i: usize = 0;
            var cnt: usize = 0;
            while (i < s.len and cnt < take) {
                const cl = std.unicode.utf8ByteSequenceLength(s[i]) catch 1;
                i += cl;
                cnt += 1;
            }
            return s[0..i];
        }
    }.call;

    // Trim trailing newlines, then split "key:desc" lines (list/viewport path).
    var src: []const u8 = bindings;
    while (src.len > 0 and src[src.len - 1] == '\n') src = src[0 .. src.len - 1];
    if (src.len == 0) return;

    var keys = std.ArrayList([]const u8).initCapacity(arena, 8) catch unreachable;
    var descs = std.ArrayList([]const u8).initCapacity(arena, 8) catch unreachable;
    var it = std.mem.splitScalar(u8, src, '\n');
    while (it.next()) |ln| {
        if (ln.len == 0) continue;
        if (std.mem.indexOfScalar(u8, ln, ':')) |cp| {
            keys.append(arena, ln[0..cp]) catch unreachable;
            descs.append(arena, ln[cp + 1 ..]) catch unreachable;
        } else {
            keys.append(arena, ln) catch unreachable;
            descs.append(arena, "") catch unreachable;
        }
    }
    const n: usize = keys.items.len;
    if (n == 0) return;

    const key_style: $mod.libvaxis.Cell.Style = .{ .fg = $mod.libvaxis.Color.rgbFromUint(@intCast(key_fg)) };
    const desc_style: $mod.libvaxis.Cell.Style = .{ .fg = $mod.libvaxis.Color.rgbFromUint(@intCast(desc_fg)) };
    const sep_style: $mod.libvaxis.Cell.Style = .{ .fg = $mod.libvaxis.Color.rgbFromUint(@intCast(sep_fg)) };

    // ---- FULL mode — one "key  desc" row per binding, key column aligned. ----
    if (mode != 0) {
        var kw: usize = 0;
        for (keys.items) |k| {
            const d = dispW(k);
            if (d > kw) kw = d;
        }
        const gap: usize = 3; // bubbles FullSeparator gap between key & desc cols
        const rows: u16 = @intCast(n);
        // Bottom-anchor the block (help hugs the screen bottom, grows upward).
        const start_y: u16 = if (h > rows) h - rows else 0;
        var r: u16 = 0;
        while (r < rows) : (r += 1) {
            const y: u16 = start_y + r;
            if (y >= h) break;
            const k = keys.items[r];
            const d = descs.items[r];
            if (k.len > 0) {
                const ko = arena.dupe(u8, k) catch k;
                const kc = win.child(.{ .x_off = 0, .y_off = y, .width = w, .height = 1 });
                _ = kc.printSegment(.{ .text = ko, .style = key_style }, .{});
            }
            const dx: u16 = @intCast(kw + gap);
            if (d.len > 0 and dx < w) {
                const dorig = arena.dupe(u8, d) catch d;
                const dc = win.child(.{ .x_off = dx, .y_off = y, .width = w - dx, .height = 1 });
                _ = dc.printSegment(.{ .text = dorig, .style = desc_style }, .{});
            }
        }
        return;
    }

    // ---- SHORT mode — single line, " • "-joined, width-truncated with "…". ----
    // Build the styled runs, measure, then paint left→right; when the content is
    // wider than the window, reserve the last column and cap it with "…".
    const Run = struct { text: []const u8, style: $mod.libvaxis.Cell.Style };
    var runs = std.ArrayList(Run).initCapacity(arena, n * 4) catch unreachable;
    var total: usize = 0;
    var bi: usize = 0;
    while (bi < n) : (bi += 1) {
        if (bi > 0) {
            runs.append(arena, .{ .text = " • ", .style = sep_style }) catch unreachable;
            total += 3;
        }
        const k = keys.items[bi];
        const d = descs.items[bi];
        if (k.len > 0) {
            runs.append(arena, .{ .text = k, .style = key_style }) catch unreachable;
            total += dispW(k);
        }
        runs.append(arena, .{ .text = " ", .style = desc_style }) catch unreachable;
        total += 1;
        if (d.len > 0) {
            runs.append(arena, .{ .text = d, .style = desc_style }) catch unreachable;
            total += dispW(d);
        }
    }

    const y0: u16 = h - 1; // bottom row (short help hugs the bottom edge)
    var col: u16 = 0;

    if (total <= @as(usize, w)) {
        for (runs.items) |run| {
            if (col >= w) break;
            const owned = arena.dupe(u8, run.text) catch run.text;
            const c = win.child(.{ .x_off = col, .y_off = y0, .width = w - col, .height = 1 });
            _ = c.printSegment(.{ .text = owned, .style = run.style }, .{});
            col += @intCast(dispW(run.text));
        }
        return;
    }

    const budget: u16 = w - 1; // reserve the last column for "…"
    for (runs.items) |run| {
        const rw: u16 = @intCast(dispW(run.text));
        if (col + rw <= budget) {
            const owned = arena.dupe(u8, run.text) catch run.text;
            const c = win.child(.{ .x_off = col, .y_off = y0, .width = w - col, .height = 1 });
            _ = c.printSegment(.{ .text = owned, .style = run.style }, .{});
            col += rw;
        } else {
            const remaining: u16 = budget - col;
            if (remaining > 0) {
                const part = takeRunes(run.text, remaining);
                const owned = arena.dupe(u8, part) catch part;
                const c = win.child(.{ .x_off = col, .y_off = y0, .width = w - col, .height = 1 });
                _ = c.printSegment(.{ .text = owned, .style = run.style }, .{});
                col += remaining;
            }
            break;
        }
    }
    const ell = arena.dupe(u8, "…") catch "…";
    const ec = win.child(.{ .x_off = col, .y_off = y0, .width = w - col, .height = 1 });
    _ = ec.printSegment(.{ .text = ell, .style = sep_style }, .{});
}

// Charm-class table — columns, header row, selectable rows (COMPONENT table).
// Matches bubbles/table: a header row (bold) over data rows; the SELECTED row
// paints in Charm pink #EE6FF8 + bold (bubbles DefaultStyles Selected = bold +
// lipgloss "212"); a dim border line under the header (bubbles' Header
// BorderBottom). Columns carry fixed widths; cell text wider than its column
// truncates with a trailing "…" (bubbles' ansi.Truncate). Cells pad 1 col on
// each side (bubbles' Cell/Header Padding(0,1)).
//
// Payload (the list/viewport/help string path — real typed []Column/[]Row is
// the deferred hole):
//   headers — "Rank|City|Country|Population" — `|`-separated column titles
//   widths  — "4|16|16|10"                   — `|`-separated column widths
//   rows    — one row per line, `|`-separated fields (bubbles FromValues)
// Selection state (cursor index) lives in the HOST store and arrives as a
// prop; host keys (j/k/g/G) mutate it — the widget OWNS the paint, NOT the
// `! key` pipeline. Scroll: page-aligned visible window keeps the selected
// row on screen (same stateless shape as list — bubbles' offset-tracking
// viewport needs widget-owned scroll state the prop rail can't hold yet;
// floated, not routed around).
// Markup tag `<table …/>` resolves via builtin wa_qual path.
~pub event table { win: koru/vaxis:Window, headers: string, widths: string, rows: string, selected: i64 }

~proc table|zig {
    if (!$mod.is_initialized) return;

    const arena = $mod.text_arena.allocator();
    const w: u16 = win.width;
    const h: u16 = win.height;
    if (w == 0 or h < 3) return;

    // bubbles/table default taste — bold header over a dim border; selected
    // row bold + Charm pink (lipgloss "212" ≈ project pink #EE6FF8).
    const sel_fg:    u32 = 0xEE6FF8; // Charm pink — selected row
    const cell_fg:   u32 = 0xC8C8D0; // soft contrast — unselected cells
    const border_fg: u32 = 0x3C3C3C; // dim — header underline

    // Display width = UTF-8 rune count (help's dispW; wide CJK not special-cased).
    const dispW = struct {
        fn call(s: []const u8) usize {
            var n: usize = 0;
            var i: usize = 0;
            while (i < s.len) {
                const cl = std.unicode.utf8ByteSequenceLength(s[i]) catch 1;
                i += cl;
                n += 1;
            }
            return n;
        }
    }.call;
    // First `take` runes of s as a byte slice (rune-safe truncation).
    const takeRunes = struct {
        fn call(s: []const u8, take: usize) []const u8 {
            var i: usize = 0;
            var cnt: usize = 0;
            while (i < s.len and cnt < take) {
                const cl = std.unicode.utf8ByteSequenceLength(s[i]) catch 1;
                i += cl;
                cnt += 1;
            }
            return s[0..i];
        }
    }.call;

    // Split a `|`-separated line into arena-owned field slices.
    const splitFields = struct {
        fn call(a: std.mem.Allocator, line: []const u8) []const []const u8 {
            var fs = std.ArrayList([]const u8).initCapacity(a, 4) catch unreachable;
            var fit = std.mem.splitScalar(u8, line, '|');
            while (fit.next()) |f| fs.append(a, f) catch unreachable;
            return fs.toOwnedSlice(a) catch unreachable;
        }
    }.call;

    // Columns: titles + widths (zip; extra of either side is ignored).
    const titles = splitFields(arena, std.mem.trim(u8, headers, "\n"));
    const wfields = splitFields(arena, std.mem.trim(u8, widths, "\n"));
    var ncols: usize = titles.len;
    if (wfields.len < ncols) ncols = wfields.len;
    if (ncols == 0) return;
    var col_w = std.ArrayList(u16).initCapacity(arena, ncols) catch unreachable;
    for (wfields[0..ncols]) |wf| {
        const v = std.fmt.parseInt(u16, std.mem.trim(u8, wf, " "), 10) catch 0;
        col_w.append(arena, if (v == 0) 1 else v) catch unreachable;
    }

    // One cell: truncate to the column width with "…" (ansi.Truncate), pad
    // left 1 (bubbles Padding(0,1)); the right pad is the column gap.
    const paintCell = struct {
        fn call(
            a: std.mem.Allocator,
            window: anytype,
            x: u16,
            y: u16,
            width_avail: u16,
            cw: u16,
            text: []const u8,
            style: anytype,
            dw: anytype,
            tr: anytype,
        ) void {
            if (x >= width_avail) return;
            const d = dw(text);
            var out: []const u8 = text;
            if (d > cw) {
                if (cw <= 1) {
                    out = "…";
                } else {
                    out = std.fmt.allocPrint(a, "{s}…", .{tr(text, cw - 1)}) catch text;
                }
            }
            const owned = a.dupe(u8, out) catch out;
            const c = window.child(.{ .x_off = x, .y_off = y, .width = width_avail - x, .height = 1 });
            _ = c.printSegment(.{ .text = owned, .style = style }, .{});
        }
    }.call;

    const header_style: $mod.libvaxis.Cell.Style = .{ .bold = true };
    const cell_style: $mod.libvaxis.Cell.Style = .{
        .fg = $mod.libvaxis.Color.rgbFromUint(@intCast(cell_fg)),
    };
    const sel_style: $mod.libvaxis.Cell.Style = .{
        .fg = $mod.libvaxis.Color.rgbFromUint(@intCast(sel_fg)),
        .bold = true,
    };
    const border_style: $mod.libvaxis.Cell.Style = .{
        .fg = $mod.libvaxis.Color.rgbFromUint(@intCast(border_fg)),
    };

    // Header row (y=0) — bold titles, each in its own column slot.
    {
        var x: u16 = 0;
        for (titles[0..ncols], col_w.items) |t, cw| {
            paintCell(arena, win, x +% 1, 0, w, cw, std.mem.trim(u8, t, " "), header_style, dispW, takeRunes);
            x +%= cw + 2; // 1 pad each side (bubbles Padding(0,1))
            if (x >= w) break;
        }
    }

    // Header underline (y=1) — dim ─ across the used table width (bubbles'
    // Header BorderBottom(true)).
    {
        var used: usize = 0;
        for (col_w.items) |cw| used += @as(usize, cw) + 2;
        if (used > @as(usize, w)) used = @as(usize, w);
        var line = std.ArrayList(u8).initCapacity(arena, used * 3) catch unreachable;
        var i: usize = 0;
        while (i < used) : (i += 1) line.appendSlice(arena, "─") catch unreachable;
        const bc = win.child(.{ .x_off = 0, .y_off = 1, .width = w, .height = 1 });
        _ = bc.printSegment(.{ .text = line.items, .style = border_style }, .{});
    }

    // Data rows — split the newline payload (list/viewport path).
    var src: []const u8 = rows;
    while (src.len > 0 and src[src.len - 1] == '\n') src = src[0 .. src.len - 1];
    if (src.len == 0) return;
    var lines = std.ArrayList([]const u8).initCapacity(arena, 8) catch unreachable;
    var it = std.mem.splitScalar(u8, src, '\n');
    while (it.next()) |l| lines.append(arena, l) catch unreachable;
    const count: u16 = @intCast(lines.items.len);
    if (count == 0) return;

    // Clamp selected into [0, count-1].
    var sel: i64 = selected;
    if (sel < 0) sel = 0;
    if (sel > @as(i64, @intCast(count)) - 1) sel = @as(i64, @intCast(count)) - 1;
    const sel_idx: u16 = @intCast(sel);

    // Visible window: rows fill y=[2, h). Page-aligned scroll keeps the
    // selected row on the visible page (list's stateless shape).
    const region_top: u16 = 2;
    const visible_rows: u16 = h - region_top;
    const page: u16 = if (count > visible_rows) @divTrunc(sel_idx, visible_rows) else 0;
    const first: u16 = page * visible_rows;

    var r: u16 = 0;
    while (r < visible_rows) : (r += 1) {
        const idx: u16 = first + r;
        if (idx >= count) break;
        const y: u16 = region_top + r;
        const is_sel = (idx == sel_idx);
        const row_style = if (is_sel) sel_style else cell_style;

        // Selected row cursor gutter — bubbles paints the whole row in the
        // Selected style; the pink+bold row IS the cursor.
        const fields = splitFields(arena, lines.items[idx]);
        var x: u16 = 0;
        var ci: usize = 0;
        while (ci < ncols) : (ci += 1) {
            const cw = col_w.items[ci];
            const ftext = if (ci < fields.len) std.mem.trim(u8, fields[ci], " ") else "";
            if (ftext.len > 0) paintCell(arena, win, x +% 1, y, w, cw, ftext, row_style, dispW, takeRunes);
            x +%= cw + 2;
            if (x >= w) break;
        }
    }
}

// ============================================================================
// VIEW — markup → flow (Svelte-for-terminal). N sibling <text> elements.
// ============================================================================
//
// `view { <text>hi</text> <text>bye</text> }` lowers AT COMPILE TIME to a CHAIN
// of real koru write-at invocations — it COMPOSES OUT OF the existing `write-at`
// event, it does not reimplement vaxis internals. Every other koru transform
// (fmt.blk, ln, sqlite3:query) generates an inline Zig body; `view` instead
// generates real event invocations and hands them back for normal codegen.
// That's the koru-native path that lets markup lower to composable flow.
//
// Each `<text>…</text>` becomes `write-at(x: 0, y: <row>, text: "…")`, stacked
// one per row, wired as a linear `|>` pipeline (a nested continuation chain —
// the exact shape the parser builds for `a |> b |> c`). The site's own trailing
// continuations (a `|> render()`, branch handlers) ride on the LAST link.
// Nesting, {{ }} interpolation, and <box> come next — each an increment on this.
~[comptime|transform]pub event view {
    source: Source,
    invocation: *const Invocation,  // the specific invocation being transformed
    item: *const Item,
    program: *const Program,
    allocator: std.mem.Allocator
} -> SiteResult

~proc view|zig {
    const ast = @import("ast");

    // Already transformed — don't re-run (mirrors fmt.blk / ln guard).
    if (invocation.inline_body != null) {
        return .{};
    }

    const flow = if (item.* == .flow)
        &item.flow
    else
        return .{};

    _ = program;

    // Parse: collect the inner text of every <text>…</text>, in source order.
    const content = source.text;
    const open_tag = "<text>";
    const close_tag = "</text>";

    var texts = std.ArrayList([]const u8).initCapacity(allocator, 4) catch unreachable;
    var scan: usize = 0;
    while (std.mem.indexOfPos(u8, content, scan, open_tag)) |op| {
        const istart = op + open_tag.len;
        const rel_close = std.mem.indexOfPos(u8, content, istart, close_tag) orelse break;
        texts.append(allocator, content[istart..rel_close]) catch unreachable;
        scan = rel_close + close_tag.len;
    }
    if (texts.items.len == 0) return .{};

    // Build one REAL write-at(x: 0, y: <row>, text: "<t>") invocation per element,
    // in the SAME module (so each flows through write-at's own codegen). Each owns
    // its module_qualifier dupe (deinit frees it — no sharing/double-free). Only
    // the last inherits the site's `return_binding` (a bind after the whole view).
    const last = texts.items.len - 1;
    const invs = allocator.alloc(ast.Invocation, texts.items.len) catch unreachable;
    for (texts.items, 0..) |t, row| {
        const args = allocator.alloc(ast.Arg, 3) catch unreachable;
        args[0] = .{
            .name = allocator.dupe(u8, "x") catch unreachable,
            .value = allocator.dupe(u8, "0") catch unreachable,
            .had_explicit_label = true,
        };
        args[1] = .{
            .name = allocator.dupe(u8, "y") catch unreachable,
            .value = std.fmt.allocPrint(allocator, "{d}", .{row}) catch unreachable,
            .had_explicit_label = true,
        };
        args[2] = .{
            .name = allocator.dupe(u8, "text") catch unreachable,
            .value = std.fmt.allocPrint(allocator, "\"{s}\"", .{t}) catch unreachable,
            .had_explicit_label = true,
        };

        const segments = allocator.alloc([]const u8, 1) catch unreachable;
        segments[0] = allocator.dupe(u8, "write-at") catch unreachable;

        invs[row] = .{
            .path = ast.DottedPath{
                .module_qualifier = if (flow.inv().path.module_qualifier) |m|
                    allocator.dupe(u8, m) catch unreachable
                else
                    null,
                .segments = segments,
            },
            .args = args,
            .return_binding = if (row == last) flow.inv().return_binding else null,
        };
    }

    // Wire the invocations into a linear `|>` pipeline: each link is a
    // branch="" / kind=terminal continuation whose node is the next write-at.
    // Build from the tail backwards; the innermost link inherits the site's own
    // trailing continuations, so a `|> render()` after `view { … }` still fires.
    var tail: []const ast.Continuation = flow.body.continuations;
    var k: usize = invs.len;
    while (k > 1) {
        k -= 1;
        const link = allocator.alloc(ast.Continuation, 1) catch unreachable;
        link[0] = .{
            .branch = allocator.dupe(u8, "") catch unreachable,
            .binding = null,
            .condition = null,
            .kind = .terminal,
            .node = .{ .invocation = invs[k] },
            .indent = 0,
            .continuations = tail,
            .location = flow.location,
        };
        tail = link;
    }

    const transformed_flow = ast.Flow{
        .body = ast.rootSite(invs[0], tail, flow.location),
        .annotations = flow.annotations,
        .pre_label = flow.pre_label,
        .super_shape = flow.super_shape,
        .is_pure = flow.is_pure,
        .is_transitively_pure = flow.is_transitively_pure,
        .impl_of = flow.impl_of,
        .location = flow.location,
        .module = flow.module,
    };

    return .{ .replacement = ast.Item{ .flow = transformed_flow } };
}

// ============================================================================
// COMPONENT — a named, reusable view that SYNTHESIZES a koru event.
// ============================================================================
//
// `component(greet) { <text>{{ name:s }}</text> }` is a DECLARATION. It doesn't
// rewrite a flow — it synthesizes a whole koru event, exactly the way `store`
// synthesizes its insert/query family (store.kz): the `{{ name:s }}` placeholders
// BECOME the event's typed input shape, and the markup becomes an implementing
// flow that paints it. The declaration is consumed; a new `greet { name: string }`
// event + its impl are appended.
//
// The payoff: `greet` is then a NORMAL koru event. You call it, branch on it with
// koru `if`, loop it with `for`, nest it — composition is koru flow, not template
// syntax. This proof does string props (`:s`, zero-alloc passthrough into write-at);
// typed/formatted props (`:d`, `:b`) ride the fmt rail next.
~[comptime|transform|pre]pub event component {
    expr: Expression,
    source: Source,
    invocation: *const Invocation,
    item: *const Item,
    program: *const Program,
    allocator: std.mem.Allocator
} -> SiteResult

~proc component|zig {
    const ast = @import("ast");
    _ = expr;
    _ = source;
    _ = invocation;
    _ = item;

    // s→string / d→i64 / f→f64 / b→bool. Only string passes through to write-at
    // as-is this rung; the rest are declared but await the fmt rail.
    const mapType = struct {
        fn call(tc: []const u8) []const u8 {
            if (std.mem.eql(u8, tc, "d")) return "i64";
            if (std.mem.eql(u8, tc, "f")) return "f64";
            if (std.mem.eql(u8, tc, "b")) return "bool";
            return "string";
        }
    }.call;

    // Helper: a fresh DottedPath dupe (deinit frees paths, so nothing is shared).
    const mkPath = struct {
        fn call(a: std.mem.Allocator, qual: ?[]const u8, seg0: []const u8) ast.DottedPath {
            const segs = a.alloc([]const u8, 1) catch unreachable;
            segs[0] = a.dupe(u8, seg0) catch unreachable;
            return .{
                .module_qualifier = if (qual) |q| a.dupe(u8, q) catch unreachable else null,
                .segments = segs,
            };
        }
    }.call;

    // Parse a child tag's attribute region (`name="World" who={{ n:s }}`, maybe
    // a trailing `/`) into event args. Two value shapes:
    //   name="World"     → arg `name: "World"` — a string LITERAL (quotes kept).
    //   name={{ who:s }} → arg `name: who` — FORWARDS the parent's `who` prop
    //                      (bare ident, no quotes), and registers `who:type` as a
    //                      PROP of the parent component (dedup against prop_name).
    // Forwarding is what makes the graph carry DATA: `page(who:"Lars")` flows
    // into `greet(name: who)`. Typed props pass straight through — the child's
    // param type is the contract; no fmt (that's only for text interpolation).
    const parseAttrs = struct {
        fn call(a: std.mem.Allocator, region: []const u8, prop_name: *std.ArrayList([]const u8), prop_type: *std.ArrayList([]const u8)) []const ast.Arg {
            var list = std.ArrayList(ast.Arg).initCapacity(a, 2) catch unreachable;
            const n = region.len;
            var i: usize = 0;
            while (i < n) {
                while (i < n and (region[i] == ' ' or region[i] == '\t' or region[i] == '\r' or region[i] == '\n' or region[i] == '/')) : (i += 1) {}
                if (i >= n) break;
                const id0 = i;
                while (i < n and region[i] != '=' and region[i] != ' ' and region[i] != '\t' and region[i] != '\r' and region[i] != '\n') : (i += 1) {}
                const aname = region[id0..i];
                if (aname.len == 0) break;
                while (i < n and (region[i] == ' ' or region[i] == '\t' or region[i] == '\r' or region[i] == '\n')) : (i += 1) {}
                if (i >= n or region[i] != '=') break;
                i += 1;
                while (i < n and (region[i] == ' ' or region[i] == '\t')) : (i += 1) {}
                if (i >= n) break;
                if (region[i] == '"') {
                    const v0 = i;
                    i += 1;
                    while (i < n and region[i] != '"') : (i += 1) {}
                    if (i < n) i += 1; // include closing quote
                    list.append(a, .{
                        .name = a.dupe(u8, aname) catch unreachable,
                        .value = a.dupe(u8, region[v0..i]) catch unreachable,
                        .had_explicit_label = true,
                    }) catch unreachable;
                } else if (i + 1 < n and region[i] == '{' and region[i + 1] == '{') {
                    const pe = std.mem.indexOfPos(u8, region, i + 2, "}}") orelse break;
                    const ph = std.mem.trim(u8, region[i + 2 .. pe], " \t");
                    i = pe + 2;
                    var ident = ph;
                    var ktype: []const u8 = "string";
                    if (std.mem.indexOfScalar(u8, ph, ':')) |cp| {
                        ident = std.mem.trim(u8, ph[0..cp], " \t");
                        ktype = mapType(std.mem.trim(u8, ph[cp + 1 ..], " \t"));
                    }
                    // Register the forwarded prop on the parent (deduped by name).
                    var seen = false;
                    for (prop_name.items) |pn| {
                        if (std.mem.eql(u8, pn, ident)) {
                            seen = true;
                            break;
                        }
                    }
                    if (!seen) {
                        prop_name.append(a, a.dupe(u8, ident) catch unreachable) catch unreachable;
                        prop_type.append(a, a.dupe(u8, ktype) catch unreachable) catch unreachable;
                    }
                    // Arg value is the bare ident — the parent's input field.
                    list.append(a, .{
                        .name = a.dupe(u8, aname) catch unreachable,
                        .value = a.dupe(u8, ident) catch unreachable,
                        .had_explicit_label = true,
                    }) catch unreachable;
                } else break;
            }
            return list.toOwnedSlice(a) catch unreachable;
        }
    }.call;

    // Synthesize a component's event + impl from its name + markup. The event's
    // typed input shape is READ OFF the {{ ident:type }} placeholders; the markup
    // becomes a write-at chain (impl_of = the event) that composes out of the
    // existing write-at event. Returns { event_decl, impl_flow }.
    const synth = struct {
        fn call(
            a: std.mem.Allocator,
            cname: []const u8,
            cmarkup: []const u8,
            wa_qual: ?[]const u8,
            cmodule: []const u8,
            cloc: anytype,
        ) [2]ast.Item {
            const close_tag = "</text>";

            // Per element: content + a kind. kind 0 = literal (no placeholder),
            // 1 = pure single STRING placeholder (`{{ x:s }}` → passthrough,
            // zero fmt), 2 = anything else with placeholders (typed/mixed/multi
            // → route through fmt:ln). el_ident holds the passthrough ident for
            // kind 1. Props (the event's typed input) are the union of every
            // placeholder across all elements, deduped by name.
            var el_content = std.ArrayList([]const u8).initCapacity(a, 4) catch unreachable;
            var el_kind = std.ArrayList(u8).initCapacity(a, 4) catch unreachable;
            var el_ident = std.ArrayList([]const u8).initCapacity(a, 4) catch unreachable;
            var prop_name = std.ArrayList([]const u8).initCapacity(a, 4) catch unreachable;
            var prop_type = std.ArrayList([]const u8).initCapacity(a, 4) catch unreachable;
            // Child-component elements (kind 3): the parsed args for that child's
            // event invocation. Text elements carry an empty slice, to stay
            // index-aligned with el_content/el_kind/el_ident.
            var el_child_args = std.ArrayList([]const ast.Arg).initCapacity(a, 4) catch unreachable;
            // Stack layout: for a kind-3 child, -1 = paint into the parent's own
            // window (a bare nested child); >=0 = this child is a StackPanel row at
            // that y-offset, so it gets a sliced sub-window instead. Index-aligned.
            var el_stack_y = std.ArrayList(i64).initCapacity(a, 4) catch unreachable;
            // Dock layout — independent of el_stack_y (a child is EITHER a stack
            // row OR a dock slot). mode 0 = not a dock child (use the stack_y path);
            // 1 = top (p = y offset, q = height); 2 = bottom (p = `up` from the
            // bottom edge, q = height); 3 = fill (p = total top band, q = total
            // bottom band). Index-aligned with el_content.
            var el_dock = std.ArrayList(struct { mode: u8, p: i64, q: i64 }).initCapacity(a, 4) catch unreachable;
            // Nested `<stack-panel dock="fill">` inside dock: null = ordinary
            // component fill; non-null = stack-panel (empty slice = LIVE stack
            // cursor returned from the component; non-empty = static children
            // flattened into the fill window). Index-aligned.
            const NestKid = struct { name: []const u8, args: []const ast.Arg };
            var el_nest = std.ArrayList(?[]const NestKid).initCapacity(a, 4) catch unreachable;

            // Walk the markup tag-by-tag, in source order. `<text>…</text>` is a
            // painted element (kinds 0/1/2, below); any OTHER tag `<name …/>` is a
            // CHILD COMPONENT — a call to that component's synthesized event (kind
            // 3). Composition is a real invocation graph in the AST, not template
            // text: `<greet name="World"/>` inside `page` becomes `page`'s impl
            // invoking `greet(name: "World")`.
            var scan: usize = 0;
            while (std.mem.indexOfScalarPos(u8, cmarkup, scan, '<')) |lt| {
                // Tag name: up to whitespace, `>`, or `/`.
                var ne = lt + 1;
                while (ne < cmarkup.len) : (ne += 1) {
                    const c = cmarkup[ne];
                    if (c == ' ' or c == '\t' or c == '\r' or c == '\n' or c == '>' or c == '/') break;
                }
                const tag = cmarkup[lt + 1 .. ne];

                if (std.mem.eql(u8, tag, "stack-panel")) {
                    // Layout container: each inner child becomes a STACKED row — laid
                    // out into a sliced sub-window at y = its position. The container
                    // computes the layout; the children never know their y. Markup
                    // tags are lowercase kebab, matching event/component names
                    // (`stack-panel`, `dock`, `todo-row`) — XAML's name-match rule,
                    // koru spelling. Pascal `<StackPanel>` is dead; it looks up a
                    // missing component and fails loud.
                    const open_gt = std.mem.indexOfScalarPos(u8, cmarkup, ne, '>') orelse break;
                    const close_sp = std.mem.indexOfPos(u8, cmarkup, open_gt + 1, "</stack-panel>") orelse break;
                    const body = cmarkup[open_gt + 1 .. close_sp];
                    scan = close_sp + "</stack-panel>".len;

                    var stack_i: i64 = 0;
                    var bscan: usize = 0;
                    while (std.mem.indexOfScalarPos(u8, body, bscan, '<')) |blt| {
                        var bne = blt + 1;
                        while (bne < body.len) : (bne += 1) {
                            const c = body[bne];
                            if (c == ' ' or c == '\t' or c == '\r' or c == '\n' or c == '>' or c == '/') break;
                        }
                        const cn = body[blt + 1 .. bne];
                        const bgt = std.mem.indexOfScalarPos(u8, body, bne, '>') orelse break;
                        const cargs = parseAttrs(a, body[bne..bgt], &prop_name, &prop_type);
                        bscan = bgt + 1;
                        el_content.append(a, a.dupe(u8, cn) catch unreachable) catch unreachable;
                        el_kind.append(a, 3) catch unreachable;
                        el_ident.append(a, "") catch unreachable;
                        el_child_args.append(a, cargs) catch unreachable;
                        el_stack_y.append(a, stack_i) catch unreachable;
                        el_dock.append(a, .{ .mode = 0, .p = 0, .q = 0 }) catch unreachable;
                        el_nest.append(a, null) catch unreachable;
                        stack_i += 1;
                    }
                    continue;
                }

                if (std.mem.eql(u8, tag, "dock")) {
                    // Dock container: each child pins to the TOP or BOTTOM edge at
                    // a fixed height; a fill child takes the middle band. Directives
                    // ride as attrs: dock="top" / dock="bottom" / dock="fill"
                    // (default fill), h="N" rows. Nested `<stack-panel dock="fill">`
                    // is a LAYOUT child (not a component name): static kids flatten
                    // into the fill window; an empty stack-panel is the LIVE fill —
                    // the component returns a `Stack` cursor for draw-time rows.
                    const open_gt = std.mem.indexOfScalarPos(u8, cmarkup, ne, '>') orelse break;
                    const close_d = std.mem.indexOfPos(u8, cmarkup, open_gt + 1, "</dock>") orelse break;
                    const body = cmarkup[open_gt + 1 .. close_d];
                    scan = close_d + "</dock>".len;

                    var d_name = std.ArrayList([]const u8).initCapacity(a, 4) catch unreachable;
                    var d_args = std.ArrayList([]const ast.Arg).initCapacity(a, 4) catch unreachable;
                    var d_mode = std.ArrayList(u8).initCapacity(a, 4) catch unreachable; // 1 top, 2 bottom, 3 fill
                    var d_h = std.ArrayList(i64).initCapacity(a, 4) catch unreachable;
                    var d_nest = std.ArrayList(?[]const NestKid).initCapacity(a, 4) catch unreachable;
                    var total_top: i64 = 0;
                    var total_bottom: i64 = 0;

                    // Pass 1 — classify every inner child, split the dock/h layout
                    // directives out of its real props, and sum the two edge bands.
                    // stack-panel is consumed through its close tag (or self-close).
                    var bscan: usize = 0;
                    while (std.mem.indexOfScalarPos(u8, body, bscan, '<')) |blt| {
                        var bne = blt + 1;
                        while (bne < body.len) : (bne += 1) {
                            const c = body[bne];
                            if (c == ' ' or c == '\t' or c == '\r' or c == '\n' or c == '>' or c == '/') break;
                        }
                        const cn = body[blt + 1 .. bne];
                        const bgt = std.mem.indexOfScalarPos(u8, body, bne, '>') orelse break;
                        const self_close = bgt > 0 and body[bgt - 1] == '/';
                        const all_args = parseAttrs(a, body[bne..bgt], &prop_name, &prop_type);

                        var mode: u8 = 3; // default = fill
                        var hval: i64 = 0;
                        var kept = std.ArrayList(ast.Arg).initCapacity(a, 2) catch unreachable;
                        for (all_args) |arg| {
                            if (std.mem.eql(u8, arg.name, "dock")) {
                                const v = std.mem.trim(u8, arg.value, "\"");
                                if (std.mem.eql(u8, v, "top")) {
                                    mode = 1;
                                } else if (std.mem.eql(u8, v, "bottom")) {
                                    mode = 2;
                                } else {
                                    mode = 3;
                                }
                            } else if (std.mem.eql(u8, arg.name, "h")) {
                                const v = std.mem.trim(u8, arg.value, "\"");
                                hval = std.fmt.parseInt(i64, v, 10) catch 0;
                            } else {
                                kept.append(a, arg) catch unreachable;
                            }
                        }

                        if (std.mem.eql(u8, cn, "stack-panel")) {
                            // Nested layout container — parse static children (if any).
                            var kids = std.ArrayList(NestKid).initCapacity(a, 4) catch unreachable;
                            if (self_close) {
                                bscan = bgt + 1;
                            } else {
                                const close_sp = std.mem.indexOfPos(u8, body, bgt + 1, "</stack-panel>") orelse break;
                                const sp_body = body[bgt + 1 .. close_sp];
                                bscan = close_sp + "</stack-panel>".len;
                                var sscan: usize = 0;
                                while (std.mem.indexOfScalarPos(u8, sp_body, sscan, '<')) |slt| {
                                    var sne = slt + 1;
                                    while (sne < sp_body.len) : (sne += 1) {
                                        const c = sp_body[sne];
                                        if (c == ' ' or c == '\t' or c == '\r' or c == '\n' or c == '>' or c == '/') break;
                                    }
                                    const kn = sp_body[slt + 1 .. sne];
                                    const sgt = std.mem.indexOfScalarPos(u8, sp_body, sne, '>') orelse break;
                                    const kargs = parseAttrs(a, sp_body[sne..sgt], &prop_name, &prop_type);
                                    sscan = sgt + 1;
                                    kids.append(a, .{ .name = a.dupe(u8, kn) catch unreachable, .args = kargs }) catch unreachable;
                                }
                            }
                            d_name.append(a, a.dupe(u8, "__stack-panel__") catch unreachable) catch unreachable;
                            d_args.append(a, kept.toOwnedSlice(a) catch unreachable) catch unreachable;
                            d_mode.append(a, mode) catch unreachable;
                            d_h.append(a, hval) catch unreachable;
                            d_nest.append(a, kids.toOwnedSlice(a) catch unreachable) catch unreachable;
                        } else {
                            bscan = bgt + 1;
                            d_name.append(a, a.dupe(u8, cn) catch unreachable) catch unreachable;
                            d_args.append(a, kept.toOwnedSlice(a) catch unreachable) catch unreachable;
                            d_mode.append(a, mode) catch unreachable;
                            d_h.append(a, hval) catch unreachable;
                            d_nest.append(a, null) catch unreachable;
                        }
                        if (mode == 1) total_top += hval;
                        if (mode == 2) total_bottom += hval;
                    }

                    // Pass 2 — emit each child as a dock slot. Top rows accumulate
                    // downward from y=0; bottom rows accumulate UP from the bottom
                    // edge (first bottom child sits lowest); the fill child carries
                    // both band totals so it spans the middle at runtime.
                    var run_top: i64 = 0;
                    var run_bottom: i64 = 0;
                    for (d_name.items, d_args.items, d_mode.items, d_h.items, d_nest.items) |cn, cargs, mode, hval, nest| {
                        var p: i64 = 0;
                        var q: i64 = 0;
                        if (mode == 1) {
                            p = run_top;
                            q = hval;
                            run_top += hval;
                        } else if (mode == 2) {
                            run_bottom += hval;
                            p = run_bottom;
                            q = hval;
                        } else {
                            p = total_top;
                            q = total_bottom;
                        }
                        el_content.append(a, cn) catch unreachable;
                        el_kind.append(a, 3) catch unreachable;
                        el_ident.append(a, "") catch unreachable;
                        el_child_args.append(a, cargs) catch unreachable;
                        el_stack_y.append(a, -1) catch unreachable;
                        el_dock.append(a, .{ .mode = mode, .p = p, .q = q }) catch unreachable;
                        el_nest.append(a, nest) catch unreachable;
                    }
                    continue;
                }

                if (!std.mem.eql(u8, tag, "text")) {
                    // Child component: `<name attr="v" .../>` (self-closing this rung).
                    // Bare (not in a container) → -1 = paints into the parent's window.
                    const gt = std.mem.indexOfScalarPos(u8, cmarkup, ne, '>') orelse break;
                    const cargs = parseAttrs(a, cmarkup[ne..gt], &prop_name, &prop_type);
                    scan = gt + 1;
                    el_content.append(a, a.dupe(u8, tag) catch unreachable) catch unreachable;
                    el_kind.append(a, 3) catch unreachable;
                    el_ident.append(a, "") catch unreachable;
                    el_child_args.append(a, cargs) catch unreachable;
                    el_stack_y.append(a, -1) catch unreachable;
                    el_dock.append(a, .{ .mode = 0, .p = 0, .q = 0 }) catch unreachable;
                    el_nest.append(a, null) catch unreachable;
                    continue;
                }

                const gt = std.mem.indexOfScalarPos(u8, cmarkup, ne, '>') orelse break;
                const istart = gt + 1;
                const rel_close = std.mem.indexOfPos(u8, cmarkup, istart, close_tag) orelse break;
                const inner = std.mem.trim(u8, cmarkup[istart..rel_close], " \t\r\n");
                scan = rel_close + close_tag.len;

                // Extract every `{{ ident:type }}` in this element → props.
                var ph_count: usize = 0;
                var last_ident: []const u8 = "";
                var last_is_string = false;
                var pscan: usize = 0;
                while (std.mem.indexOfPos(u8, inner, pscan, "{{")) |ps| {
                    const pe = std.mem.indexOfPos(u8, inner, ps + 2, "}}") orelse break;
                    const ph = std.mem.trim(u8, inner[ps + 2 .. pe], " \t");
                    pscan = pe + 2;
                    var ident = ph;
                    var ktype: []const u8 = "string";
                    var is_string = true;
                    if (std.mem.indexOfScalar(u8, ph, ':')) |cp| {
                        ident = std.mem.trim(u8, ph[0..cp], " \t");
                        const tc = std.mem.trim(u8, ph[cp + 1 ..], " \t");
                        ktype = mapType(tc);
                        is_string = std.mem.eql(u8, ktype, "string");
                    }
                    ph_count += 1;
                    last_ident = ident;
                    last_is_string = is_string;
                    // Dedupe: a prop named the same way across elements is one field.
                    var seen = false;
                    for (prop_name.items) |pn| {
                        if (std.mem.eql(u8, pn, ident)) {
                            seen = true;
                            break;
                        }
                    }
                    if (!seen) {
                        prop_name.append(a, ident) catch unreachable;
                        prop_type.append(a, ktype) catch unreachable;
                    }
                }

                const is_pure = ph_count == 1 and std.mem.startsWith(u8, inner, "{{") and std.mem.endsWith(u8, inner, "}}");
                if (ph_count == 0) {
                    el_kind.append(a, 0) catch unreachable;
                    el_ident.append(a, "") catch unreachable;
                } else if (is_pure and last_is_string) {
                    el_kind.append(a, 1) catch unreachable;
                    el_ident.append(a, last_ident) catch unreachable;
                } else {
                    el_kind.append(a, 2) catch unreachable;
                    el_ident.append(a, "") catch unreachable;
                }
                el_content.append(a, inner) catch unreachable;
                el_child_args.append(a, &[_]ast.Arg{}) catch unreachable;
                el_stack_y.append(a, -1) catch unreachable;
                el_dock.append(a, .{ .mode = 0, .p = 0, .q = 0 }) catch unreachable;
                el_nest.append(a, null) catch unreachable;
            }

    // Builtin meter/spinner/textinput/list/viewport/paginator/help/table tags resolve
    // to koru/vaxis events (not consumer-module components). wa_qual path.
    const childQual = struct {
        fn call(name: []const u8, waq: ?[]const u8, cmod: []const u8) ?[]const u8 {
            if (std.mem.eql(u8, name, "progress-bar")) return waq orelse "koru/vaxis";
            if (std.mem.eql(u8, name, "spinner")) return waq orelse "koru/vaxis";
            if (std.mem.eql(u8, name, "text-input")) return waq orelse "koru/vaxis";
            if (std.mem.eql(u8, name, "list")) return waq orelse "koru/vaxis";
            if (std.mem.eql(u8, name, "viewport")) return waq orelse "koru/vaxis";
            if (std.mem.eql(u8, name, "paginator")) return waq orelse "koru/vaxis";
            if (std.mem.eql(u8, name, "help")) return waq orelse "koru/vaxis";
            if (std.mem.eql(u8, name, "table")) return waq orelse "koru/vaxis";
            return cmod;
        }
    }.call;

            // (1)+(2) build ops first — a live empty StackPanel fill may set
            // return_type on the event (returns Stack for draw-time rows).
            const mkWriteIn = struct {
                fn call(al: std.mem.Allocator, waq: ?[]const u8, mkp: anytype, row: usize, text_val: []const u8) ast.Invocation {
                    const args = al.alloc(ast.Arg, 4) catch unreachable;
                    args[0] = .{ .name = al.dupe(u8, "win") catch unreachable, .value = al.dupe(u8, "win") catch unreachable, .had_explicit_label = true };
                    args[1] = .{ .name = al.dupe(u8, "x") catch unreachable, .value = al.dupe(u8, "0") catch unreachable, .had_explicit_label = true };
                    args[2] = .{ .name = al.dupe(u8, "y") catch unreachable, .value = std.fmt.allocPrint(al, "{d}", .{row}) catch unreachable, .had_explicit_label = true };
                    args[3] = .{ .name = al.dupe(u8, "text") catch unreachable, .value = text_val, .had_explicit_label = true };
                    return .{ .path = mkp(al, waq, "write-in"), .args = args };
                }
            }.call;

            var ops = std.ArrayList(ast.Invocation).initCapacity(a, 8) catch unreachable;
            var lctr: usize = 0;
            var sctr: usize = 0;
            var live_stack_bind: ?[]const u8 = null;
            for (el_content.items, el_kind.items, el_ident.items, el_child_args.items, el_stack_y.items, el_dock.items, el_nest.items, 0..) |content, kind, ident, cargs, stack_y, dock, nest, row| {
                if (kind == 0) {
                    ops.append(a, mkWriteIn(a, wa_qual, mkPath, row, std.fmt.allocPrint(a, "\"{s}\"", .{content}) catch unreachable)) catch unreachable;
                } else if (kind == 1) {
                    ops.append(a, mkWriteIn(a, wa_qual, mkPath, row, a.dupe(u8, ident) catch unreachable)) catch unreachable;
                } else if (kind == 2) {
                    const lname = std.fmt.allocPrint(a, "__view_l{d}", .{lctr}) catch unreachable;
                    lctr += 1;
                    // std/fmt:ln("<content>"): <lname>
                    const ln_args = a.alloc(ast.Arg, 1) catch unreachable;
                    ln_args[0] = .{ .name = a.dupe(u8, "expr") catch unreachable, .value = std.fmt.allocPrint(a, "\"{s}\"", .{content}) catch unreachable };
                    ops.append(a, .{ .path = mkPath(a, "std.fmt", "ln"), .args = ln_args, .return_binding = a.dupe(u8, lname) catch unreachable }) catch unreachable;
                    // write-in(win, x:0, y:row, text: <lname>.text)
                    ops.append(a, mkWriteIn(a, wa_qual, mkPath, row, std.fmt.allocPrint(a, "{s}.text", .{lname}) catch unreachable)) catch unreachable;
                } else if (dock.mode > 0) {
                    // kind 3, DOCK slot — the container carves a sub-window per
                    // child by mode, then invokes the child INTO that slice. Same
                    // two-op shape as a StackPanel row; only the slicing primitive
                    // and its args differ:
                    //   1 top    -> sub(parent, x:0, y:p, w:0, h:q)   fixed top rows
                    //   2 bottom -> sub-from-bottom(parent, up:p, h:q) pinned to edge
                    //   3 fill   -> sub-fill(parent, top:p, bottom:q)  runtime middle
                    // Nested StackPanel fill: carve, then either flatten static
                    // children into the fill window or return a live Stack cursor.
                    const rname = std.fmt.allocPrint(a, "__row_{d}", .{sctr}) catch unreachable;
                    sctr += 1;
                    var slot: ast.Invocation = undefined;
                    if (dock.mode == 1) {
                        const sa = a.alloc(ast.Arg, 5) catch unreachable;
                        sa[0] = .{ .name = a.dupe(u8, "parent") catch unreachable, .value = a.dupe(u8, "win") catch unreachable, .had_explicit_label = true };
                        sa[1] = .{ .name = a.dupe(u8, "x") catch unreachable, .value = a.dupe(u8, "0") catch unreachable, .had_explicit_label = true };
                        sa[2] = .{ .name = a.dupe(u8, "y") catch unreachable, .value = std.fmt.allocPrint(a, "{d}", .{dock.p}) catch unreachable, .had_explicit_label = true };
                        sa[3] = .{ .name = a.dupe(u8, "w") catch unreachable, .value = a.dupe(u8, "0") catch unreachable, .had_explicit_label = true };
                        sa[4] = .{ .name = a.dupe(u8, "h") catch unreachable, .value = std.fmt.allocPrint(a, "{d}", .{dock.q}) catch unreachable, .had_explicit_label = true };
                        slot = .{ .path = mkPath(a, wa_qual, "sub"), .args = sa, .return_binding = a.dupe(u8, rname) catch unreachable };
                    } else if (dock.mode == 2) {
                        const sa = a.alloc(ast.Arg, 3) catch unreachable;
                        sa[0] = .{ .name = a.dupe(u8, "parent") catch unreachable, .value = a.dupe(u8, "win") catch unreachable, .had_explicit_label = true };
                        sa[1] = .{ .name = a.dupe(u8, "up") catch unreachable, .value = std.fmt.allocPrint(a, "{d}", .{dock.p}) catch unreachable, .had_explicit_label = true };
                        sa[2] = .{ .name = a.dupe(u8, "h") catch unreachable, .value = std.fmt.allocPrint(a, "{d}", .{dock.q}) catch unreachable, .had_explicit_label = true };
                        slot = .{ .path = mkPath(a, wa_qual, "sub-from-bottom"), .args = sa, .return_binding = a.dupe(u8, rname) catch unreachable };
                    } else {
                        const sa = a.alloc(ast.Arg, 3) catch unreachable;
                        sa[0] = .{ .name = a.dupe(u8, "parent") catch unreachable, .value = a.dupe(u8, "win") catch unreachable, .had_explicit_label = true };
                        sa[1] = .{ .name = a.dupe(u8, "top") catch unreachable, .value = std.fmt.allocPrint(a, "{d}", .{dock.p}) catch unreachable, .had_explicit_label = true };
                        sa[2] = .{ .name = a.dupe(u8, "bottom") catch unreachable, .value = std.fmt.allocPrint(a, "{d}", .{dock.q}) catch unreachable, .had_explicit_label = true };
                        slot = .{ .path = mkPath(a, wa_qual, "sub-fill"), .args = sa, .return_binding = a.dupe(u8, rname) catch unreachable };
                    }
                    ops.append(a, slot) catch unreachable;
                    if (nest) |kids| {
                        if (kids.len == 0) {
                            // LIVE fill — stack cursor over the carved window;
                            // component returns it for draw-time stack-row.
                            const lname = std.fmt.allocPrint(a, "__live_stack", .{}) catch unreachable;
                            const sa = a.alloc(ast.Arg, 1) catch unreachable;
                            sa[0] = .{ .name = a.dupe(u8, "parent") catch unreachable, .value = a.dupe(u8, rname) catch unreachable, .had_explicit_label = true };
                            ops.append(a, .{ .path = mkPath(a, wa_qual, "stack"), .args = sa, .return_binding = a.dupe(u8, lname) catch unreachable }) catch unreachable;
                            live_stack_bind = lname;
                        } else {
                            for (kids, 0..) |kid, ki| {
                                const krname = std.fmt.allocPrint(a, "__row_{d}", .{sctr}) catch unreachable;
                                sctr += 1;
                                const sub_args = a.alloc(ast.Arg, 5) catch unreachable;
                                sub_args[0] = .{ .name = a.dupe(u8, "parent") catch unreachable, .value = a.dupe(u8, rname) catch unreachable, .had_explicit_label = true };
                                sub_args[1] = .{ .name = a.dupe(u8, "x") catch unreachable, .value = a.dupe(u8, "0") catch unreachable, .had_explicit_label = true };
                                sub_args[2] = .{ .name = a.dupe(u8, "y") catch unreachable, .value = std.fmt.allocPrint(a, "{d}", .{ki}) catch unreachable, .had_explicit_label = true };
                                sub_args[3] = .{ .name = a.dupe(u8, "w") catch unreachable, .value = a.dupe(u8, "0") catch unreachable, .had_explicit_label = true };
                                sub_args[4] = .{ .name = a.dupe(u8, "h") catch unreachable, .value = a.dupe(u8, "1") catch unreachable, .had_explicit_label = true };
                                ops.append(a, .{ .path = mkPath(a, wa_qual, "sub"), .args = sub_args, .return_binding = a.dupe(u8, krname) catch unreachable }) catch unreachable;
                                const child_args = a.alloc(ast.Arg, kid.args.len + 1) catch unreachable;
                                child_args[0] = .{ .name = a.dupe(u8, "win") catch unreachable, .value = a.dupe(u8, krname) catch unreachable, .had_explicit_label = true };
                                for (kid.args, 0..) |ca, ci| child_args[ci + 1] = ca;
                                ops.append(a, .{ .path = mkPath(a, childQual(kid.name, wa_qual, cmodule), kid.name), .args = child_args }) catch unreachable;
                            }
                        }
                    } else {
                        const child_args = a.alloc(ast.Arg, cargs.len + 1) catch unreachable;
                        child_args[0] = .{ .name = a.dupe(u8, "win") catch unreachable, .value = a.dupe(u8, rname) catch unreachable, .had_explicit_label = true };
                        for (cargs, 0..) |ca, ci| child_args[ci + 1] = ca;
                        ops.append(a, .{ .path = mkPath(a, childQual(content, wa_qual, cmodule), content), .args = child_args }) catch unreachable;
                    }
                } else if (stack_y < 0) {
                    // kind 3, BARE — child component painting into the parent's OWN
                    // window. `content` is the child NAME; `cargs` its parsed args.
                    // Builtin widgets (`progress-bar`, `spinner`, `text-input`, `list`)
                    // resolve via wa_qual; user components via cmodule. Forward
                    // this component's `win` down.
                    const child_args = a.alloc(ast.Arg, cargs.len + 1) catch unreachable;
                    child_args[0] = .{ .name = a.dupe(u8, "win") catch unreachable, .value = a.dupe(u8, "win") catch unreachable, .had_explicit_label = true };
                    for (cargs, 0..) |ca, ci| child_args[ci + 1] = ca;
                    ops.append(a, .{ .path = mkPath(a, childQual(content, wa_qual, cmodule), content), .args = child_args }) catch unreachable;
                } else {
                    // kind 3, STACKED — a StackPanel row. The container slices its
                    // `win` into a full-width, 1-row sub-window at y=stack_y, then
                    // invokes the child INTO that slice. Two ops: `sub(parent: win,
                    // x:0, y:stack_y, w:0, h:1): __row_N` then `child(win: __row_N, …)`.
                    // The child never knows its y — layout is the container's job.
                    const rname = std.fmt.allocPrint(a, "__row_{d}", .{sctr}) catch unreachable;
                    sctr += 1;
                    const sub_args = a.alloc(ast.Arg, 5) catch unreachable;
                    sub_args[0] = .{ .name = a.dupe(u8, "parent") catch unreachable, .value = a.dupe(u8, "win") catch unreachable, .had_explicit_label = true };
                    sub_args[1] = .{ .name = a.dupe(u8, "x") catch unreachable, .value = a.dupe(u8, "0") catch unreachable, .had_explicit_label = true };
                    sub_args[2] = .{ .name = a.dupe(u8, "y") catch unreachable, .value = std.fmt.allocPrint(a, "{d}", .{stack_y}) catch unreachable, .had_explicit_label = true };
                    sub_args[3] = .{ .name = a.dupe(u8, "w") catch unreachable, .value = a.dupe(u8, "0") catch unreachable, .had_explicit_label = true };
                    sub_args[4] = .{ .name = a.dupe(u8, "h") catch unreachable, .value = a.dupe(u8, "1") catch unreachable, .had_explicit_label = true };
                    ops.append(a, .{ .path = mkPath(a, wa_qual, "sub"), .args = sub_args, .return_binding = a.dupe(u8, rname) catch unreachable }) catch unreachable;
                    const child_args = a.alloc(ast.Arg, cargs.len + 1) catch unreachable;
                    child_args[0] = .{ .name = a.dupe(u8, "win") catch unreachable, .value = a.dupe(u8, rname) catch unreachable, .had_explicit_label = true };
                    for (cargs, 0..) |ca, ci| child_args[ci + 1] = ca;
                    ops.append(a, .{ .path = mkPath(a, childQual(content, wa_qual, cmodule), content), .args = child_args }) catch unreachable;
                }
            }

            // Event decl: cname { win: Window, <props> } [-> Stack when live fill].
            const fields = a.alloc(ast.Field, prop_name.items.len + 1) catch unreachable;
            fields[0] = .{
                .name = a.dupe(u8, "win") catch unreachable,
                .type = a.dupe(u8, "Window") catch unreachable,
                .module_path = a.dupe(u8, wa_qual orelse "koru/vaxis") catch unreachable,
            };
            for (prop_name.items, prop_type.items, 0..) |pn, pt, i| {
                fields[i + 1] = .{ .name = a.dupe(u8, pn) catch unreachable, .type = a.dupe(u8, pt) catch unreachable };
            }
            const event_item = ast.Item{ .event_decl = ast.EventDecl{
                .path = mkPath(a, cmodule, cname),
                .input = ast.Shape{ .fields = fields },
                .branches = &[_]ast.Branch{},
                .return_type = if (live_stack_bind != null) a.dupe(u8, "koru/vaxis:Stack") catch unreachable else null,
                .is_public = false,
                .is_implicit_flow = false,
                .annotations = &[_][]const u8{},
                .location = cloc,
                .module = a.dupe(u8, cmodule) catch unreachable,
            } };

            // Chain the ops into a linear `|>` pipeline (nested continuations).
            // Live StackPanel fill ends with `-> __live_stack` bare return.
            var tail: []const ast.Continuation = if (live_stack_bind) |lsb| blk: {
                const br = a.alloc(ast.Continuation, 1) catch unreachable;
                br[0] = .{
                    .branch = a.dupe(u8, "") catch unreachable,
                    .binding = null,
                    .condition = null,
                    .kind = .terminal,
                    .node = .{ .branch_constructor = .{
                        .branch_name = a.dupe(u8, "") catch unreachable,
                        .fields = &[_]ast.Field{},
                        .plain_value = a.dupe(u8, lsb) catch unreachable,
                        .is_bare_return = true,
                    } },
                    .indent = 0,
                    .continuations = &[_]ast.Continuation{},
                    .location = cloc,
                };
                break :blk br;
            } else &[_]ast.Continuation{};
            var k: usize = ops.items.len;
            while (k > 1) {
                k -= 1;
                const link = a.alloc(ast.Continuation, 1) catch unreachable;
                link[0] = .{
                    .branch = a.dupe(u8, "") catch unreachable,
                    .binding = null,
                    .condition = null,
                    .kind = .terminal,
                    .node = .{ .invocation = ops.items[k] },
                    .indent = 0,
                    .continuations = tail,
                    .location = cloc,
                };
                tail = link;
            }

            const impl_item = ast.Item{ .flow = ast.Flow{
                .body = ast.rootSite(ops.items[0], tail, cloc),
                .impl_of = mkPath(a, cmodule, cname),
                .is_pure = false,
                .is_transitively_pure = false,
                .location = cloc,
                .module = a.dupe(u8, cmodule) catch unreachable,
            } };

            return .{ event_item, impl_item };
        }
    }.call;

    // WHOLE-PROGRAM WALK (Lars 2026-07-22): a library transform holds the whole
    // AST, so `component` walks it, finds EVERY `component(name){…}` declaration,
    // synthesizes each event + impl, consumes the declarations, and hands back the
    // fully-rewritten program. Returning `whole_program` (vs per-site `.appended`)
    // is what makes the synthesized events visible to downstream passes — the
    // shape checker builds its event set from `program.items`, so the events must
    // BE there before it runs. No language or pipeline change; just the whole-
    // program-transform capability koru already gives library-level transforms.
    var new_items = std.ArrayList(ast.Item).initCapacity(allocator, program.items.len + 8) catch unreachable;
    var synthed = std.ArrayList(ast.Item).initCapacity(allocator, 8) catch unreachable;
    var found = false;

    for (program.items) |pi| {
        const is_component = pi == .flow and blk: {
            const segs = pi.flow.inv().path.segments;
            break :blk segs.len > 0 and std.mem.eql(u8, segs[segs.len - 1], "component");
        };
        if (!is_component) {
            new_items.append(allocator, pi) catch unreachable;
            continue;
        }

        // Read the name + markup off the declaration. The markup rides the
        // `source` arg; the name is the positional expr arg — which at this
        // pre-mapping stage carries its own value as its name (not yet "expr").
        const cinv = pi.flow.inv();
        var name: []const u8 = "";
        var markup: []const u8 = "";
        for (cinv.args) |arg| {
            if (std.mem.eql(u8, arg.name, "source")) {
                markup = arg.value;
            } else {
                name = arg.value;
                if (name.len >= 2 and name[0] == '"' and name[name.len - 1] == '"') name = name[1 .. name.len - 1];
            }
        }
        if (name.len == 0) {
            new_items.append(allocator, pi) catch unreachable;
            continue;
        }

        found = true;
        const pair = synth(allocator, name, markup, cinv.path.module_qualifier, pi.flow.module, pi.flow.location);
        synthed.append(allocator, pair[0]) catch unreachable;
        synthed.append(allocator, pair[1]) catch unreachable;

        // Consume the declaration → a host-line comment in its place.
        const consumed = std.fmt.allocPrint(allocator, "// koru/vaxis: component '{s}' synthesized → event + write-at impl", .{name}) catch unreachable;
        new_items.append(allocator, ast.Item{ .host_line = ast.HostLine{
            .content = consumed,
            .location = pi.flow.location,
            .module = allocator.dupe(u8, pi.flow.module) catch unreachable,
        } }) catch unreachable;
    }

    if (!found) return .{};

    for (synthed.items) |si| {
        new_items.append(allocator, si) catch unreachable;
    }

    const new_prog = allocator.create(ast.Program) catch unreachable;
    new_prog.* = .{
        .items = new_items.toOwnedSlice(allocator) catch unreachable,
        .module_annotations = program.module_annotations,
        .main_module_name = program.main_module_name,
        .allocator = program.allocator,
        .type_registry = program.type_registry,
    };
    return .{ .whole_program = new_prog };
}
