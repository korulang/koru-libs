// Feature coverage — group.count, match.start, the no-match case (loop body
// simply never fires), and the loud err branch for an uncompilable pattern.
//
// EXPECTED output:
//   groups=2 start=0 word=2015
//   groups=2 start=5 word=12
//   groups=2 start=8 word=25
//   scanned
//   nomatch-ok
//   bad pattern at offset 1

~import libs/pcre2
~import std/io

// (1) Three matches of a two-group date-ish pattern; read count + start offset.
~libs/pcre2:compile(pattern: "(\\d+)")
| ok re |> libs/pcre2:find.all(re, subject: "2015-12-25")
    ! match m |> libs/pcre2:group.count(m): n |> libs/pcre2:match.start(m): at |> libs/pcre2:group.text(m, index: 1): w |> std/io:print.ln("groups={{ n:d }} start={{ at:d }} word={{ w:s }}")
    | done |> libs/pcre2:free(re) |> std/io:print.ln("scanned")
    | err e |> libs/pcre2:free(re) |> std/io:print.ln("err: {{ e.msg:s }}")
| err e |> std/io:print.ln("compile err: {{ e.msg:s }}")

// (2) No match: the ! match body never fires, we go straight to done.
~libs/pcre2:compile(pattern: "zzz")
| ok re |> libs/pcre2:find.all(re, subject: "no digits here")
    ! match _ |> std/io:print.ln("SHOULD NOT FIRE")
    | done |> libs/pcre2:free(re) |> std/io:print.ln("nomatch-ok")
    | err e |> libs/pcre2:free(re) |> std/io:print.ln("err: {{ e.msg:s }}")
| err e |> std/io:print.ln("compile err: {{ e.msg:s }}")

// (3) Uncompilable pattern: unmatched '(' — the err branch fires loudly with
// PCRE2's own diagnostic and the byte offset it choked on. No silent fallback.
~libs/pcre2:compile(pattern: "(")
| ok re |> libs/pcre2:free(re) |> std/io:print.ln("SHOULD NOT COMPILE")
| err e |> std/io:print.ln("bad pattern at offset {{ e.offset:d }}")
