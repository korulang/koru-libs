// Reach a real scalar and extract its text. A bare YAML scalar document emits
// STREAM-START, DOCUMENT-START, then the SCALAR, so two advances land on the
// value. The borrowed slice is read BEFORE `finish` frees the event.

~import libs/yaml
~import std/io

~libs/yaml:open(input: "hello world")
| ok p |> libs/yaml:begin(parser: p)
    | at c |> libs/yaml:advance(cur: c)
        | at c2 |> libs/yaml:advance(cur: c2)
            | at c3 |> libs/yaml:scalar(cur: c3)
                | value v |> std/io:print.ln("scalar = {{ v.text:s }}") |> libs/yaml:finish(v.cur)
                | other o |> std/io:print.ln("event 3 was not a scalar") |> libs/yaml:finish(cur: o)
            | eof e3 |> libs/yaml:close(parser: e3) |> std/io:print.ln("eof@3")
            | err x3 |> libs/yaml:close(parser: x3) |> std/io:print.ln("err@3")
        | eof e2 |> libs/yaml:close(parser: e2) |> std/io:print.ln("eof@2")
        | err x2 |> libs/yaml:close(parser: x2) |> std/io:print.ln("err@2")
    | eof pp |> libs/yaml:close(parser: pp) |> std/io:print.ln("empty stream")
    | err ep |> libs/yaml:close(parser: ep) |> std/io:print.ln("parse error")
| err e |> std/io:print.ln("open error: {{ e:s }}")

pub fn main() void {}
