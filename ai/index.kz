// @koru/ai - AI SDK for Koru
//
// A first-class Koru edition of LLM text generation over the Anthropic and
// OpenAI HTTP APIs. Built on @koru/curl — dogfooding our own lifted HTTP
// client. The lift is entirely in the type system: a request-in-flight carries
// a `built!` free-obligation and the HTTP response carries curl's `open!`
// close-obligation, so the compiler will not let a caller leak the request
// scratch OR forget to close the connection. Two obligations, both enforced,
// discharged in the caller's flow. Non-streaming: one request, one reply.
//
// ── Shape & history (why it looks like this) ─────────────────────────────────
// The pre-current-language edition of this file (a) declared bare `~proc`s
// (KORU110: bare procs are unresolvable in the current language) and (b) called
// curl through an INVENTED Zig escape hatch —
// `@import("root").koru_libs.curl.post_with_headers_event.call(.{...})` — a
// symbol attested by no passing test. This edition removes both. Composition
// with curl now uses the sanctioned koru-level, cross-module event form
// (`koru/curl:post.with-headers(...)`, `koru/curl:close(...)`) in flow position,
// grounded in tests/regression/100_MODULE_SYSTEM/110_IMPORTS/
// 110_020_cross_module_literal_arg and koru-by-example's subflow section.
//
// The API is a set of building-block events the caller wires in a top-level
// flow (see examples/ and README.md), NOT a single `generate(...)` convenience
// event. That is a deliberate, forced choice: a single all-in-one event would
// have to be a subflow that borrow-parses the response, discharges it, and
// produces a value — and that exact shape is blocked by three current compiler
// gaps (see LIFT_NOTES.md "Toolchain findings"). The building-block flow sits
// entirely in top-level flow position, which the compiler handles cleanly and
// which — bonus — makes BOTH obligations visible at the call site.

~import koru/curl

const std = @import("std");

// ============================================================================
// Types
// ============================================================================

pub const Usage = struct {
    input_tokens: i64,
    output_tokens: i64,
};

// A parsed, OWNED generation result. `text`, `model` and `stop_reason` are
// duped out of the (borrowed) HTTP response body, so the result outlives the
// `koru/curl:close` that frees that body.
pub const GenerateResult = struct {
    text: []const u8,
    usage: Usage,
    model: []const u8,
    stop_reason: []const u8,
    allocator: std.mem.Allocator,
};

pub const Error = struct {
    code: i32,
    msg: []const u8,
    provider: []const u8,
};

// A built request in flight. Carries the phantom `built!` obligation: it MUST
// be discharged with `free.request`, or the build fails at compile time. `url`
// is a static provider endpoint; `body` is heap-allocated JSON owned here.
pub const Request = struct {
    url: []const u8,
    body: []const u8,
    allocator: std.mem.Allocator,
};

// ============================================================================
// Request builders — provider-specific JSON, produced as a `built!` obligation
// ============================================================================

~pub event request.anthropic {
    model: []const u8,
    prompt: []const u8,
    system: ?[]const u8,
    max_tokens: ?i32,
    allocator: ?std.mem.Allocator
} -> *Request<built!>

~proc request.anthropic|zig {
    const alloc = allocator orelse std.heap.page_allocator;
    var buf = std.ArrayList(u8).initCapacity(alloc, 256) catch unreachable;
    const w = buf.writer(alloc);

    w.writeAll("{") catch unreachable;
    w.print("\"model\":\"{s}\",", .{model}) catch unreachable;
    w.print("\"max_tokens\":{d},", .{max_tokens orelse 1024}) catch unreachable;
    if (system) |sys| {
        w.writeAll("\"system\":\"") catch unreachable;
        writeJsonEscaped(w, sys) catch unreachable;
        w.writeAll("\",") catch unreachable;
    }
    w.writeAll("\"messages\":[{\"role\":\"user\",\"content\":\"") catch unreachable;
    writeJsonEscaped(w, prompt) catch unreachable;
    w.writeAll("\"}]}") catch unreachable;

    return makeRequest(alloc, "https://api.anthropic.com/v1/messages", buf.toOwnedSlice(alloc) catch unreachable);
}

~pub event request.openai {
    model: []const u8,
    prompt: []const u8,
    system: ?[]const u8,
    max_tokens: ?i32,
    allocator: ?std.mem.Allocator
} -> *Request<built!>

~proc request.openai|zig {
    const alloc = allocator orelse std.heap.page_allocator;
    var buf = std.ArrayList(u8).initCapacity(alloc, 256) catch unreachable;
    const w = buf.writer(alloc);

    w.writeAll("{") catch unreachable;
    w.print("\"model\":\"{s}\",", .{model}) catch unreachable;
    w.print("\"max_tokens\":{d},", .{max_tokens orelse 1024}) catch unreachable;
    w.writeAll("\"messages\":[") catch unreachable;
    if (system) |sys| {
        w.writeAll("{\"role\":\"system\",\"content\":\"") catch unreachable;
        writeJsonEscaped(w, sys) catch unreachable;
        w.writeAll("\"},") catch unreachable;
    }
    w.writeAll("{\"role\":\"user\",\"content\":\"") catch unreachable;
    writeJsonEscaped(w, prompt) catch unreachable;
    w.writeAll("\"}]}") catch unreachable;

    return makeRequest(alloc, "https://api.openai.com/v1/chat/completions", buf.toOwnedSlice(alloc) catch unreachable);
}

// Discharge the request's `built!` obligation. Frees the JSON body and the
// Request struct. Omit this call in a flow and the build fails (KORU030).
~pub event free.request { req: *Request<!built> }
~proc free.request|zig {
    req.allocator.free(req.body);
    req.allocator.destroy(req);
}

fn makeRequest(alloc: std.mem.Allocator, url: []const u8, body: []const u8) *Request {
    const req = alloc.create(Request) catch unreachable;
    req.* = .{ .url = url, .body = body, .allocator = alloc };
    return req;
}

// ============================================================================
// Response parsers — BORROW the curl response, produce an OWNED result
// ============================================================================
// These take the response as `<koru/curl:open>` (a borrow, never a consume):
// the caller still owes the `koru/curl:close`. They dupe every returned byte
// out of the response body, so the result survives that close.

~pub event parse.anthropic { resp: *koru/curl:Response<koru/curl:open> }
| ok GenerateResult
| err Error

~proc parse.anthropic|zig {
    const alloc = std.heap.page_allocator;
    const body = resp.body;

    if (resp.status != 200) {
        return .{ .err = .{ .code = resp.status, .msg = alloc.dupe(u8, body) catch "API error", .provider = "anthropic" } };
    }

    // {"content":[{"type":"text","text":"..."}],"model":"...",
    //  "stop_reason":"...","usage":{"input_tokens":N,"output_tokens":N}}
    const text_key = "\"text\":\"";
    const text_kpos = std.mem.indexOf(u8, body, text_key) orelse {
        return .{ .err = .{ .code = -1, .msg = "Failed to parse response: no text field", .provider = "anthropic" } };
    };
    const text_start = text_kpos + text_key.len;
    const text_end = findJsonStringEnd(body, text_start);
    const text = unescapeJson(body[text_start..text_end], alloc) catch {
        return .{ .err = .{ .code = -1, .msg = "Failed to unescape text", .provider = "anthropic" } };
    };

    return .{ .ok = .{
        .text = text,
        .usage = .{
            .input_tokens = parseIntField(body, "\"input_tokens\":"),
            .output_tokens = parseIntField(body, "\"output_tokens\":"),
        },
        .model = parseStringField(body, "\"model\":\"", alloc),
        .stop_reason = parseStringField(body, "\"stop_reason\":\"", alloc),
        .allocator = alloc,
    } };
}

~pub event parse.openai { resp: *koru/curl:Response<koru/curl:open> }
| ok GenerateResult
| err Error

~proc parse.openai|zig {
    const alloc = std.heap.page_allocator;
    const body = resp.body;

    if (resp.status != 200) {
        return .{ .err = .{ .code = resp.status, .msg = alloc.dupe(u8, body) catch "API error", .provider = "openai" } };
    }

    // {"choices":[{"message":{"content":"..."},"finish_reason":"stop"}],
    //  "usage":{"prompt_tokens":N,"completion_tokens":N},"model":"..."}
    const content_key = "\"content\":\"";
    const content_kpos = std.mem.indexOf(u8, body, content_key) orelse {
        return .{ .err = .{ .code = -1, .msg = "Failed to parse response: no content field", .provider = "openai" } };
    };
    const content_start = content_kpos + content_key.len;
    const content_end = findJsonStringEnd(body, content_start);
    const text = unescapeJson(body[content_start..content_end], alloc) catch {
        return .{ .err = .{ .code = -1, .msg = "Failed to unescape text", .provider = "openai" } };
    };

    return .{ .ok = .{
        .text = text,
        .usage = .{
            .input_tokens = parseIntField(body, "\"prompt_tokens\":"),
            .output_tokens = parseIntField(body, "\"completion_tokens\":"),
        },
        .model = parseStringField(body, "\"model\":\"", alloc),
        .stop_reason = parseStringField(body, "\"finish_reason\":\"", alloc),
        .allocator = alloc,
    } };
}

// ============================================================================
// Shared JSON helpers (pure std — no provider, no curl dependency)
// ============================================================================

// Index of the closing unescaped quote of a JSON string starting at `start`.
fn findJsonStringEnd(body: []const u8, start: usize) usize {
    var i = start;
    var in_escape = false;
    while (i < body.len) : (i += 1) {
        if (in_escape) {
            in_escape = false;
            continue;
        }
        if (body[i] == '\\') {
            in_escape = true;
            continue;
        }
        if (body[i] == '"') break;
    }
    return i;
}

fn parseIntField(body: []const u8, key: []const u8) i64 {
    if (std.mem.indexOf(u8, body, key)) |pos| {
        const num_start = pos + key.len;
        var num_end = num_start;
        while (num_end < body.len and body[num_end] >= '0' and body[num_end] <= '9') : (num_end += 1) {}
        return std.fmt.parseInt(i64, body[num_start..num_end], 10) catch 0;
    }
    return 0;
}

fn parseStringField(body: []const u8, key: []const u8, alloc: std.mem.Allocator) []const u8 {
    if (std.mem.indexOf(u8, body, key)) |pos| {
        const s_start = pos + key.len;
        const s_end = findJsonStringEnd(body, s_start);
        return alloc.dupe(u8, body[s_start..s_end]) catch "unknown";
    }
    return "unknown";
}

fn writeJsonEscaped(writer: anytype, s: []const u8) !void {
    for (s) |ch| {
        switch (ch) {
            '"' => try writer.writeAll("\\\""),
            '\\' => try writer.writeAll("\\\\"),
            '\n' => try writer.writeAll("\\n"),
            '\r' => try writer.writeAll("\\r"),
            '\t' => try writer.writeAll("\\t"),
            else => {
                if (ch < 0x20) {
                    try writer.print("\\u{x:0>4}", .{ch});
                } else {
                    try writer.writeByte(ch);
                }
            },
        }
    }
}

fn unescapeJson(s: []const u8, alloc: std.mem.Allocator) ![]const u8 {
    var result = try std.ArrayList(u8).initCapacity(alloc, s.len);
    errdefer result.deinit(alloc);

    var i: usize = 0;
    while (i < s.len) {
        if (s[i] == '\\' and i + 1 < s.len) {
            switch (s[i + 1]) {
                '"' => try result.append(alloc, '"'),
                '\\' => try result.append(alloc, '\\'),
                'n' => try result.append(alloc, '\n'),
                'r' => try result.append(alloc, '\r'),
                't' => try result.append(alloc, '\t'),
                else => {
                    try result.append(alloc, s[i]);
                    try result.append(alloc, s[i + 1]);
                },
            }
            i += 2;
        } else {
            try result.append(alloc, s[i]);
            i += 1;
        }
    }

    return result.toOwnedSlice(alloc);
}
