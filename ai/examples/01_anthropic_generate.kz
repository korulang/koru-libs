// Example: one-shot text generation against the Anthropic Messages API.
//
// The building-block flow, top to bottom:
//   1. koru/ai:request.anthropic  -> builds provider JSON, yields *Request<built!>
//   2. koru/curl:post.with-headers -> sends it, yields *Response<open!>
//   3. koru/ai:parse.anthropic     -> borrows the response, yields an OWNED result
//   4. koru/curl:close             -> discharges the response obligation
//   5. koru/ai:free.request        -> discharges the request obligation
//
// BOTH obligations are visible right here at the call site. Delete either the
// close or the free.request and the program will not compile.
//
// Run it (a real HTTPS call; export your key or edit the literal):
//   koruc run ai/examples/01_anthropic_generate.kz
// With a placeholder key the endpoint returns 401 and the `err` arm fires —
// which is itself a faithful end-to-end run of the whole stack.

~import koru/ai
~import koru/curl
~import std/io

~koru/ai:request.anthropic(model: "claude-sonnet-4-20250514", prompt: "What is a phantom type? One sentence.", system: null, max_tokens: 256, allocator: null): req |> koru/curl:post.with-headers(req.url, req.body, headers: &.{ .{ .name = "Content-Type", .value = "application/json" }, .{ .name = "x-api-key", .value = "sk-ant-REPLACE-ME" }, .{ .name = "anthropic-version", .value = "2023-06-01" } })
    | ok resp |> koru/ai:parse.anthropic(resp)
        | ok result |> std/io:print.blk {
            === AI Response ===
            Model: {{ result.model:s }}
            Text: {{ result.text:s }}
            Tokens: {{ result.usage.input_tokens:d }} in / {{ result.usage.output_tokens:d }} out
            Stop: {{ result.stop_reason:s }}
            } |> koru/curl:close(resp) |> koru/ai:free.request(req)
        | err e |> std/io:print.ln("API error [{{ e.code:d }}] from {{ e.provider:s }}: {{ e.msg:s }}") |> koru/curl:close(resp) |> koru/ai:free.request(req)
    | err e |> std/io:print.ln("Transport error [{{ e.code:d }}]: {{ e.msg:s }}") |> koru/ai:free.request(req)
